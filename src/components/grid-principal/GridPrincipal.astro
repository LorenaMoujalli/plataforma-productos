---
import "../../styles/grid-principal/grid-principal.css";
import "../../styles/grid-principal/benefit-card.css";
import FilterBar from "./FilterBar.astro";
import Pagination from "./Pagination.astro";
---

<div class="benefits-container">
  <FilterBar />

  <div class="benefits-grid" id="benefits-grid">
    <!-- Las cards se renderizan dinámicamente desde Supabase -->
  </div>

  <Pagination />
</div>

<script>
  import { getCoupons } from "../../services/coupons.js";

  // ── Helpers ──────────────────────────────────────────────────
  function esc(str: unknown): string {
    if (str == null) return "";
    return String(str)
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;");
  }

  // ── Genera el HTML de una card (idéntico a BenefitCard.astro) ─
  function renderCard(coupon: any): string {
    const company        = coupon.companies ?? {};
    const logoSrc        = esc(company.logo_url   ?? "");
    const companyName    = esc(company.name        ?? "");
    const title          = esc(coupon.title        ?? "");
    const description    = coupon.description      ?? "";   // puede tener HTML
    const vigencia       = esc(coupon.vigencia     ?? "");
    const tipoDescuento  = esc(coupon.tipo_descuento ?? "");
    const discountAmount = esc(coupon.discount_amount ?? "XXXX");
    const discountLabel  = esc(coupon.discount_label  ?? "DE DESCUENTO");
    const codeLabel      = esc(coupon.code_label      ?? "Usando el código");
    const discountCode   = esc(coupon.discount_code   ?? "XXXXXXXXXX");
    const benefitText    = coupon.benefit_text ?? "";       // puede tener HTML
    const terms          = coupon.terms        ?? "";       // puede tener HTML

    return `
      <article class="benefit-card">

        <!-- FRONT -->
        <div class="card-front">
          <div class="card-header">
            <img src="${logoSrc}" alt="Logo" class="brand-logo" />
            <button type="button" class="btn-benefit btn-flip">Ver beneficio</button>
          </div>
          <div class="card-body">
            <h3>${title}</h3>
            <span class="company-name">${companyName}</span>
            <p class="description">${description}</p>
          </div>
          <div class="card-footer">
            <div class="info-row">
              <span class="info-label">Vigencia:</span> ${vigencia}
            </div>
            <div class="info-row">
              <span class="info-label">Tipo de descuento:</span> ${tipoDescuento}
            </div>
          </div>
        </div>

        <!-- BACK -->
        <div class="card-back hidden">
          <div class="back-header">
            <button type="button" class="btn-back btn-flip" aria-label="Regresar">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                   xmlns="http://www.w3.org/2000/svg">
                <path d="M10 19L3 12M3 12L10 5M3 12H13C16.866 12 20 15.134 20 19V20"
                      stroke="black" stroke-width="2"
                      stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="discount-info">
              <span class="discount-amount">${discountAmount}</span>
              <span class="discount-label">${discountLabel}</span>
            </div>
          </div>
          <div class="back-body">
            <p class="code-text">${codeLabel} <strong>${discountCode}</strong></p>
            ${benefitText ? `<p class="benefit-text">${benefitText}</p>` : ""}
            <h4>Términos y condiciones</h4>
            <p class="terms-text">${terms}</p>
          </div>
        </div>

      </article>
    `;
  }

  // ── Paginación ───────────────────────────────────────────────
  function initPagination(): void {
    const cards = document.querySelectorAll<HTMLElement>(".benefit-card");
    const paginationContainer = document.getElementById("pagination-container");

    if (!paginationContainer || cards.length === 0) return;

    // Reasignamos a const para que TypeScript sepa que ya no es null
    const container = paginationContainer;

    const itemsPerPage = 6;
    const totalPages   = Math.ceil(cards.length / itemsPerPage);

    function showPage(page: number): void {
      cards.forEach((card, index) => {
        const inRange =
          index >= (page - 1) * itemsPerPage && index < page * itemsPerPage;
        card.style.display = inRange ? "flex" : "none";
      });
      container
        .querySelectorAll<HTMLElement>(".page-num")
        .forEach((btn, i) => btn.classList.toggle("active", i === page - 1));
    }

    if (totalPages > 1) {
      container.innerHTML = "";
      for (let i = 1; i <= totalPages; i++) {
        const btn       = document.createElement("a");
        btn.href        = "#";
        btn.className   = `page-num${i === 1 ? " active" : ""}`;
        btn.textContent = String(i);
        btn.addEventListener("click", (e) => {
          e.preventDefault();
          showPage(i);
          document
            .querySelector(".search-filter-title")
            ?.scrollIntoView({ behavior: "smooth", block: "start" });
        });
        container.appendChild(btn);
      }
      showPage(1);
    } else {
      showPage(1);
      container.style.display = "none";
    }
  }

  // ── Flip de cards (delegación de eventos) ───────────────────
  function setupFlip(grid: HTMLElement): void {
    grid.addEventListener("click", (e) => {
      const btn = (e.target as Element).closest<HTMLElement>(".btn-flip");
      if (!btn) return;
      const card  = btn.closest<HTMLElement>(".benefit-card");
      const front = card?.querySelector<HTMLElement>(".card-front");
      const back  = card?.querySelector<HTMLElement>(".card-back");
      if (front && back) {
        front.classList.toggle("hidden");
        back.classList.toggle("hidden");
      }
    });
  }

  // ── Carga principal ──────────────────────────────────────────
  async function loadCoupons(): Promise<void> {
    const grid = document.getElementById("benefits-grid");
    if (!grid) return;

    try {
      const coupons = await getCoupons();
      grid.innerHTML = coupons.map(renderCard).join("");
      setupFlip(grid);
      initPagination();
    } catch (err) {
      console.error("Error cargando cupones:", err);
      grid.innerHTML =
        '<p style="color:#64748b;padding:2rem;text-align:center;">Error al cargar los beneficios. Intenta refrescar la página.</p>';
    }
  }

  loadCoupons();
</script>
