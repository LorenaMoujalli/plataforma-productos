---
import "../../styles/banner-home/banner-home.css";
import BannerMedia from "./BannerMedia.astro";
import BannerContent from "./BannerContent.astro";

export interface Props {
  title?: string;
}

const {
  title = "Programa Socio a Socio: Beneficios exclusivos para nuestra red",
} = Astro.props;
---

<section class="banner">
  <BannerMedia />
  <BannerContent title={title} />
</section>
