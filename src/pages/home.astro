---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Home"> 
	hola
</DashboardLayout>

<style>
	.dashboard-grid {
		display: grid;
		grid-template-columns: 2fr 1fr;
		gap: 1.5rem;
		width: 100%;
	}

	.main-column {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.side-column {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.stats-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5rem;
	}

	/* ========================================
	   RESPONSIVE MEDIA QUERIES
	   ======================================== */

	/* Tablet */
	@media (max-width: 1023px) {
		.dashboard-grid {
			grid-template-columns: 1fr;
			gap: 1.25rem;
		}

		.stats-row {
			gap: 1.25rem;
		}
	}

	/* Mobile */
	@media (max-width: 767px) {
		.dashboard-grid {
			gap: 1rem;
		}

		.main-column,
		.side-column {
			gap: 1rem;
		}

		.stats-row {
			gap: 1rem;
		}
	}

	/* Mobile small */
	@media (max-width: 480px) {
		.stats-row {
			grid-template-columns: 1fr;
		}
	}
</style>
