---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Administración de Usuarios - Oberstaff">
  <div class="admin-container">
    <a href="/home" class="back-link">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="19" y1="12" x2="5" y2="12"></line>
        <polyline points="12 19 5 12 12 5"></polyline>
      </svg>
      Volver
    </a>

    <div class="admin-header">
      <div class="header-titles">
        <div class="title-row">
          <h1>Panel de Administración</h1>
          <div class="admin-tabs">
            <button class="tab-btn tab-active" data-tab="usuarios">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
              </svg>
              Usuarios
            </button>
            <button class="tab-btn" data-tab="dominios">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="2" y1="12" x2="22" y2="12"></line>
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
              </svg>
              Dominios
            </button>
            <button class="tab-btn" data-tab="cupon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                <line x1="7" y1="7" x2="7.01" y2="7"></line>
              </svg>
              Cupón
            </button>
          </div>
        </div>
        <p id="tab-subtitle">Gestiona los usuarios de la plataforma.</p>
      </div>
      <!-- Acciones tab Usuarios -->
      <div class="header-actions" id="usuarios-actions">
        <div class="search-box">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          <input type="text" id="search-user" placeholder="Buscar por nombre o correo...">
        </div>
        <button id="add-user-btn" class="btn-success">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
          </svg>
          Nuevo Usuario
        </button>
      </div>

      <!-- Acciones tab Dominios -->
      <div class="header-actions" id="dominios-actions" style="display:none;">
        <div class="search-box">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          <input type="text" id="search-domain" placeholder="Buscar dominio...">
        </div>
        <button id="add-domain-btn" class="btn-success">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
          </svg>
          Nuevo Dominio
        </button>
      </div>

      <!-- Acciones tab Cupones -->
      <div class="header-actions" id="cupones-actions" style="display:none;">
        <div class="search-box">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          <input type="text" id="search-cupon" placeholder="Buscar cupón o empresa...">
        </div>
        <button id="add-cupon-btn" class="btn-success">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
          </svg>
          Nuevo Cupón
        </button>
      </div>
    </div>

    <!-- Mensajes de estado -->
    <div id="status-message" class="status-message" style="display: none;"></div>

    <!-- Panel: Usuarios -->
    <div id="panel-usuarios" class="tab-panel">
      <div class="table-container">
        <div id="loading-state" class="loading-state">
          <div class="spinner"></div>
          <p>Cargando usuarios...</p>
        </div>

        <table id="users-table" class="users-table" style="display: none;">
          <thead>
            <tr>
              <th>Nombre</th>
              <th>Correo Electrónico</th>
              <th>Rol</th>
              <th>Fecha de Registro</th>
              <th class="text-right">Acciones</th>
            </tr>
          </thead>
          <tbody id="users-tbody">
            <!-- Las filas se renderizarán dinámicamente aquí -->
          </tbody>
        </table>

        <div id="empty-state" class="empty-state" style="display: none;">
          <p>No se encontraron usuarios o hubo un error al cargar los datos.</p>
        </div>
      </div>
    </div>

    <!-- Panel: Dominios -->
    <div id="panel-dominios" class="tab-panel" style="display:none;">
      <div class="table-container">
        <div id="loading-state-domains" class="loading-state">
          <div class="spinner"></div>
          <p>Cargando dominios...</p>
        </div>

        <table id="domains-table" class="users-table" style="display: none;">
          <thead>
            <tr>
              <th>Dominio</th>
              <th>Fecha de Registro</th>
              <th class="text-right">Acciones</th>
            </tr>
          </thead>
          <tbody id="domains-tbody">
          </tbody>
        </table>

        <div id="empty-state-domains" class="empty-state" style="display: none;">
          <p>No hay dominios registrados aún.</p>
        </div>
      </div>
    </div>

    <!-- Panel: Cupón -->
    <div id="panel-cupon" class="tab-panel" style="display:none;">
      <div class="table-container">
        <div id="loading-state-cupons" class="loading-state">
          <div class="spinner"></div>
          <p>Cargando cupones...</p>
        </div>
        <table id="cupons-table" class="users-table" style="display:none;">
          <thead>
            <tr>
              <th>Empresa</th>
              <th>Título</th>
              <th>Vigencia</th>
              <th>Tipo</th>
              <th style="text-align:center;">Estado</th>
              <th class="text-right">Acciones</th>
            </tr>
          </thead>
          <tbody id="cupons-tbody"></tbody>
        </table>
        <div id="empty-state-cupons" class="empty-state" style="display:none;">
          <p>No hay cupones registrados aún.</p>
        </div>
      </div>
    </div>

  </div><!-- /.admin-container -->

  <!-- ══ Modal Cupón ══════════════════════════════════════════════ -->
  <div id="cm-overlay" class="cm-overlay" style="display:none;">
    <div class="cm-dialog">
      <div class="cm-header">
        <h2 id="cm-modal-title">Nuevo Cupón</h2>
        <button id="cm-close-btn" class="cm-close-btn" type="button">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>

      <div class="cm-body">

        <!-- Empresa -->
        <div class="cm-section">
          <h3 class="cm-section-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
            Empresa
          </h3>
          <div class="cm-field">
            <label for="cm-company-id">Empresa *</label>
            <select id="cm-company-id" class="cm-input cm-select">
              <option value="">Cargando empresas...</option>
            </select>
          </div>
          <div class="cm-row">
            <div class="cm-field">
              <label for="cm-sort-order">Orden de visualización</label>
              <input id="cm-sort-order" type="number" min="0" class="cm-input" placeholder="0" value="0">
            </div>
            <div class="cm-field cm-field-toggle">
              <label>Estado inicial</label>
              <label class="cm-toggle">
                <input type="checkbox" id="cm-active" checked>
                <span class="cm-toggle-slider"></span>
              </label>
              <span id="cm-active-label" class="cm-toggle-text">Activo (visible en home)</span>
            </div>
          </div>
        </div>

        <!-- Cara Frontal -->
        <div class="cm-section">
          <h3 class="cm-section-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            Cara Frontal
          </h3>
          <div class="cm-field">
            <label for="cm-title">Título *</label>
            <input id="cm-title" type="text" class="cm-input" placeholder="Ej: Descuento especial para socios">
          </div>
          <div class="cm-field">
            <label for="cm-description">Descripción <span class="cm-hint">— Puede contener HTML básico (&lt;br/&gt;, &lt;strong&gt;)</span></label>
            <textarea id="cm-description" class="cm-input cm-textarea" rows="4" placeholder="Descripción visible en la cara frontal de la tarjeta..."></textarea>
          </div>
          <div class="cm-row">
            <div class="cm-field">
              <label for="cm-vigencia">Vigencia</label>
              <input id="cm-vigencia" type="text" class="cm-input" placeholder="Ej: 01/01/26 - 31/12/26">
            </div>
            <div class="cm-field">
              <label for="cm-tipo-descuento">Tipo de descuento</label>
              <select id="cm-tipo-descuento" class="cm-input cm-select">
                <option value="Descuento porcentual">Descuento porcentual</option>
                <option value="Otro">Otro</option>
                <option value="No especificado">No especificado</option>
              </select>
            </div>
          </div>
        </div>

        <!-- Cara del Reverso -->
        <div class="cm-section">
          <h3 class="cm-section-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
            Cara del Reverso
          </h3>
          <div class="cm-row">
            <div class="cm-field">
              <label for="cm-discount-amount">Cantidad de descuento</label>
              <input id="cm-discount-amount" type="text" class="cm-input" placeholder="Ej: 10%, $300, XXXX">
            </div>
            <div class="cm-field">
              <label for="cm-discount-label">Etiqueta del descuento</label>
              <input id="cm-discount-label" type="text" class="cm-input" placeholder="Ej: DE DESCUENTO">
            </div>
          </div>
          <div class="cm-row">
            <div class="cm-field">
              <label for="cm-code-label">Texto antes del código</label>
              <input id="cm-code-label" type="text" class="cm-input" placeholder="Ej: Usando el código">
            </div>
            <div class="cm-field">
              <label for="cm-discount-code">Código</label>
              <input id="cm-discount-code" type="text" class="cm-input" placeholder="Ej: PROMO2026">
            </div>
          </div>
          <div class="cm-field">
            <label for="cm-benefit-text">Texto de beneficio <span class="cm-hint">— Puede contener HTML básico</span></label>
            <textarea id="cm-benefit-text" class="cm-input cm-textarea" rows="3" placeholder="Párrafo adicional que aparece en el reverso (opcional)..."></textarea>
          </div>
          <div class="cm-field">
            <label for="cm-terms">Términos y condiciones <span class="cm-hint">— Puede contener HTML básico</span></label>
            <textarea id="cm-terms" class="cm-input cm-textarea" rows="4" placeholder="Escribe los términos y condiciones del cupón..."></textarea>
          </div>
        </div>

      </div><!-- /.cm-body -->

      <div class="cm-footer">
        <button id="cm-cancel-btn" type="button" class="cm-btn-cancel">Cancelar</button>
        <button id="cm-save-btn" type="button" class="cm-btn-save">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
          Guardar Cupón
        </button>
      </div>
    </div>
  </div>
  <!-- ══════════════════════════════════════════════════════════ -->
</DashboardLayout>

<script>
  import { getUserProfile, getAdminUsers, deleteAdminUser, adminCreateUser, adminUpdateUser } from "../../services/auth.js";
  import { getDomains, addDomain, updateDomain, deleteDomain, getAllowedDomainNames } from "../../services/domains.js";
  import { getAdminCoupons, getCompaniesForSelect, createCoupon, updateCoupon, deleteCoupon, toggleCouponActive } from "../../services/coupons-admin.js";
  import { showConfirm, showToast, showCreateUserModal, showEditUserModal, showCreateDomainModal, showEditDomainModal } from "../../utils/notifications.js";

  function setupDashboard() {
    // Solo ejecutar en la ruta del dashboard
    if (!window.location.pathname.includes('/admin/dashboard')) return;

    // Dominios permitidos (para pasarlos a los modales de usuario)
    let allowedDomains: string[] = [];
    getAllowedDomainNames().then(d => { allowedDomains = d; }).catch(() => {});

    // Elementos del DOM
    const loadingState = document.getElementById("loading-state");
    const usersTable = document.getElementById("users-table");
    const usersTbody = document.getElementById("users-tbody");
    const emptyState = document.getElementById("empty-state");
    const statusMessage = document.getElementById("status-message");
    const searchInput = document.getElementById("search-user") as HTMLInputElement;

    let allUsers: any[] = []; // Guardamos los usuarios globalmente para filtrarlos

    // ── Tab switching ──────────────────────────────────────────
    const tabBtns = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
    const tabPanels: Record<string, HTMLElement | null> = {
      usuarios: document.getElementById('panel-usuarios'),
      dominios: document.getElementById('panel-dominios'),
      cupon:    document.getElementById('panel-cupon'),
    };
    const usuariosActions = document.getElementById('usuarios-actions');
    const dominiosActions = document.getElementById('dominios-actions');
    const cuponesActions  = document.getElementById('cupones-actions');
    const tabSubtitle = document.getElementById('tab-subtitle');

    const subtitles: Record<string, string> = {
      usuarios: 'Gestiona los usuarios de la plataforma.',
      dominios: 'Administra los dominios autorizados para registro.',
      cupon:    'Crea y gestiona cupones de descuento.',
    };

    let domainsLoaded = false;
    let cuponesLoaded = false;

    function switchTab(tab: string) {
      tabBtns.forEach(btn => btn.classList.remove('tab-active'));
      const activeBtn = document.querySelector<HTMLButtonElement>(`.tab-btn[data-tab="${tab}"]`);
      if (activeBtn) activeBtn.classList.add('tab-active');

      Object.entries(tabPanels).forEach(([key, panel]) => {
        if (panel) panel.style.display = key === tab ? 'block' : 'none';
      });

      if (usuariosActions) usuariosActions.style.display = tab === 'usuarios' ? 'flex' : 'none';
      if (dominiosActions) dominiosActions.style.display = tab === 'dominios' ? 'flex' : 'none';
      if (cuponesActions)  cuponesActions.style.display  = tab === 'cupon'    ? 'flex' : 'none';

      if (tabSubtitle) tabSubtitle.textContent = subtitles[tab] ?? '';

      if (tab === 'dominios' && !domainsLoaded) { domainsLoaded = true; loadDomains(); }
      if (tab === 'cupon'    && !cuponesLoaded) { cuponesLoaded = true; loadCupons(); }
    }

    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const tab = btn.getAttribute('data-tab');
        if (tab) switchTab(tab);
      });
    });
    // ──────────────────────────────────────────────────────────

    // Event listener para el buscador
    if (searchInput) {
      searchInput.addEventListener('input', () => {
        if (allUsers.length > 0) {
          renderUsers(allUsers);
        }
      });
    }

    // Mostrar mensajes
    function showMessage(msg: string, type: string = "success") {
      if (!statusMessage) return;
      statusMessage.textContent = msg;
      statusMessage.className = `status-message ${type}`;
      statusMessage.style.display = "block";
      
      // Ocultar después de 4 segundos
      setTimeout(() => {
        statusMessage.style.display = "none";
      }, 4000);
    }

    // Formatear fecha
    function formatDate(dateString: string | Date | null | undefined) {
      if (!dateString) return "N/A";
      const options: Intl.DateTimeFormatOptions = { year: 'numeric', month: 'short', day: 'numeric' };
      return new Date(dateString).toLocaleDateString('es-ES', options);
    }

    // Cargar usuarios
    async function loadUsers() {
      if (!loadingState || !usersTable || !emptyState) return;
      
      try {
        loadingState.style.display = "flex";
        usersTable.style.display = "none";
        emptyState.style.display = "none";

        const users = await getAdminUsers();

        if (!users || users.length === 0) {
          emptyState.style.display = "block";
        } else {
          allUsers = users;
          renderUsers(allUsers);
          usersTable.style.display = "table";
        }
      } catch (error) {
        console.error("Error al cargar usuarios:", error);
        emptyState.style.display = "block";
        emptyState.innerHTML = `<p>Error al cargar usuarios. Verifica que tienes permisos de administrador.</p>`;
      } finally {
        loadingState.style.display = "none";
      }
    }

    // Renderizar filas de usuarios
    function renderUsers(users: any[]) {
      if (!usersTbody) return;
      usersTbody.innerHTML = "";
      
      const query = (searchInput?.value || "").toLowerCase().trim();
      const filteredUsers = users.filter((u: any) => {
        const nameMatch = (u.name || "").toLowerCase().includes(query);
        const emailMatch = (u.email || "").toLowerCase().includes(query);
        return nameMatch || emailMatch;
      });

      if (filteredUsers.length === 0) {
        usersTbody.innerHTML = '<tr><td colspan="5" style="text-align:center; padding:3rem; color:#64748b;">No se encontraron usuarios que coincidan con tu búsqueda.</td></tr>';
        return;
      }

      filteredUsers.forEach((user: any) => {
        const tr = document.createElement("tr");
        
        // Estilo especial para admin badge
        const roleBadge = user.role === 'admin' 
          ? `<span class="badge badge-admin">Admin</span>` 
          : `<span class="badge badge-user">Usuario</span>`;

        tr.innerHTML = `
          <td data-label="Nombre">
            <div class="user-info">
              <span class="font-medium">${user.name || 'Sin nombre'}</span>
            </div>
          </td>
          <td data-label="Correo"><span class="text-gray">${user.email}</span></td>
          <td data-label="Rol">${roleBadge}</td>
          <td data-label="Fecha Registro"><span class="text-gray">${formatDate(user.created_at)}</span></td>
          <td data-label="Acciones" class="actions-cell">
            <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
              <button class="btn-icon btn-edit" data-user='${JSON.stringify({id: user.id, email: user.email, name: user.name, role: user.role}).replace(/'/g, "&apos;")}' title="Editar usuario">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                  <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                </svg>
              </button>
              ${user.role !== 'admin' ? `
                <button class="btn-icon btn-delete" data-id="${user.id}" data-email="${user.email}" title="Eliminar usuario">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="3 6 5 6 21 6"></polyline>
                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                    <line x1="10" y1="11" x2="10" y2="17"></line>
                    <line x1="14" y1="11" x2="14" y2="17"></line>
                  </svg>
                </button>
              ` : '<span class="text-muted text-sm" style="display: flex; align-items: center;">No eliminable</span>'}
            </div>
          </td>
        `;
        
        usersTbody.appendChild(tr);
      });

      // Agregar event listeners a los botones de eliminar
      document.querySelectorAll('.btn-delete').forEach(element => {
        const btn = element as HTMLButtonElement;
        btn.addEventListener('click', async (e) => {
          const userId = btn.getAttribute('data-id') as string;
          const userEmail = btn.getAttribute('data-email');
          
          const isConfirmed = await showConfirm({
            title: "¿Estás seguro?",
            text: `¿Deseas eliminar permanentemente al usuario ${userEmail}? Esta acción no se puede deshacer.`,
            confirmButtonText: "Sí, eliminar",
            cancelButtonText: "Cancelar"
          });

          if (isConfirmed) {
            btn.classList.add('loading');
            btn.disabled = true;
            
            try {
              await deleteAdminUser(userId);
              showToast({ text: `El usuario ${userEmail} ha sido eliminado.`, icon: 'success' });
              loadUsers(); // Recargar la tabla
            } catch (error: any) {
              console.error("Error eliminando usuario:", error);
              showToast({ text: `Hubo un error al eliminar el usuario: ${error.message}`, icon: 'error' });
              btn.classList.remove('loading');
              btn.disabled = false;
            }
          }
        });
      });

      // Agregar event listeners a los botones de editar
      document.querySelectorAll('.btn-edit').forEach(element => {
        const btn = element as HTMLButtonElement;
        btn.addEventListener('click', async () => {
          const userDataRaw = btn.getAttribute('data-user');
          if (!userDataRaw) return;
          
          const user = JSON.parse(userDataRaw);
          const newValues: any = await showEditUserModal(user, allowedDomains);
          
          if (newValues) {
            btn.classList.add('loading');
            try {
              await adminUpdateUser(user.id, newValues.name, newValues.role, newValues.email, newValues.password);
              showToast({ text: `Usuario actualizado correctamente.`, icon: 'success' });
              loadUsers();
            } catch (error: any) {
              console.error("Error actualizando usuario:", error);
              
              // Si falla por RLS, mostrar mensaje amigable
              if (error.message.includes("Row Level Security") || error.message.includes("RLS") || error.message.includes("not allowed")) {
                showToast({ text: `Necesitamos crear un permiso SQL (RPC) para actualizar perfiles.`, icon: 'error' });
              } else {
                showToast({ text: `Error: ${error.message}`, icon: 'error' });
              }
              btn.classList.remove('loading');
            }
          }
        });
      });
    }

    // Configurar botón de Nuevo Usuario
    const addUserBtn = document.getElementById('add-user-btn') as HTMLButtonElement;
    if (addUserBtn) {
      addUserBtn.addEventListener('click', async () => {
        const userData: any = await showCreateUserModal(allowedDomains);
        if (userData) {
          try {
            addUserBtn.disabled = true;
            addUserBtn.innerHTML = '<span class="spinner" style="width:20px;height:20px;border-width:2px;margin-right:8px;"></span> Registrando...';
            
            await adminCreateUser(userData.email, userData.password, userData.name, userData.role);
            
            showToast({ text: `Usuario ${userData.email} creado con éxito.`, icon: 'success' });
            loadUsers(); // Recargar la tabla
          } catch (error: any) {
            console.error("Error creando usuario:", error);
            showToast({ text: `Error: ${error.message}`, icon: 'error' });
          } finally {
            addUserBtn.disabled = false;
            addUserBtn.innerHTML = `
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
              </svg>
              Nuevo Usuario
            `;
          }
        }
      });
    }

    // ── Gestión de Dominios ──────────────────────────────────────
    const loadingStateDomains = document.getElementById("loading-state-domains");
    const domainsTable = document.getElementById("domains-table");
    const domainsTbody = document.getElementById("domains-tbody");
    const emptyStateDomains = document.getElementById("empty-state-domains");
    const searchDomainInput = document.getElementById("search-domain") as HTMLInputElement;

    let allDomains: any[] = [];

    if (searchDomainInput) {
      searchDomainInput.addEventListener('input', () => {
        if (allDomains.length > 0) renderDomains(allDomains);
      });
    }

    async function loadDomains() {
      if (!loadingStateDomains || !domainsTable || !emptyStateDomains) return;

      loadingStateDomains.style.display = "flex";
      domainsTable.style.display = "none";
      emptyStateDomains.style.display = "none";

      try {
        const domains = await getDomains();
        if (!domains || domains.length === 0) {
          emptyStateDomains.style.display = "block";
        } else {
          allDomains = domains;
          renderDomains(allDomains);
          domainsTable.style.display = "table";
        }
      } catch (error: any) {
        console.error("Error al cargar dominios:", error);
        emptyStateDomains.style.display = "block";
        emptyStateDomains.innerHTML = `<p>Error al cargar dominios: ${error.message}</p>`;
      } finally {
        loadingStateDomains.style.display = "none";
      }
    }

    function renderDomains(domains: any[]) {
      if (!domainsTbody) return;
      domainsTbody.innerHTML = "";

      const query = (searchDomainInput?.value || "").toLowerCase().trim();
      const filtered = domains.filter((d: any) =>
        (d.domain || "").toLowerCase().includes(query)
      );

      if (filtered.length === 0) {
        domainsTbody.innerHTML = '<tr><td colspan="3" style="text-align:center; padding:3rem; color:#64748b;">No se encontraron dominios.</td></tr>';
        return;
      }

      filtered.forEach((d: any) => {
        const tr = document.createElement("tr");
        tr.innerHTML = `
          <td data-label="Dominio">
            <div style="display:flex; align-items:center; gap:0.8rem;">
              <div style="width:36px;height:36px;border-radius:10px;background:#f1f5f9;border:1px solid #e2e8f0;display:flex;align-items:center;justify-content:center;">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#64748b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"></circle>
                  <line x1="2" y1="12" x2="22" y2="12"></line>
                  <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                </svg>
              </div>
              <span class="font-medium">${d.domain}</span>
            </div>
          </td>
          <td data-label="Fecha Registro"><span class="text-gray">${formatDate(d.created_at)}</span></td>
          <td data-label="Acciones" class="actions-cell">
            <div style="display:flex;gap:0.5rem;justify-content:flex-end;">
              <button class="btn-icon btn-edit-domain" data-id="${d.id}" data-domain="${d.domain}" title="Editar dominio">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                  <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                </svg>
              </button>
              <button class="btn-icon btn-delete-domain" data-id="${d.id}" data-domain="${d.domain}" title="Eliminar dominio">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="3 6 5 6 21 6"></polyline>
                  <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                  <line x1="10" y1="11" x2="10" y2="17"></line>
                  <line x1="14" y1="11" x2="14" y2="17"></line>
                </svg>
              </button>
            </div>
          </td>
        `;
        domainsTbody.appendChild(tr);
      });

      // Listeners editar
      document.querySelectorAll('.btn-edit-domain').forEach(el => {
        const btn = el as HTMLButtonElement;
        btn.addEventListener('click', async () => {
          const id = parseInt(btn.getAttribute('data-id') as string);
          const domain = btn.getAttribute('data-domain') as string;
          const result: any = await showEditDomainModal({ id, domain });
          if (result) {
            btn.classList.add('loading');
            try {
              await updateDomain(id, result.domain);
              showToast({ text: `Dominio actualizado correctamente.`, icon: 'success' });
              domainsLoaded = false;
              loadDomains();
            } catch (error: any) {
              showToast({ text: `Error: ${error.message}`, icon: 'error' });
              btn.classList.remove('loading');
            }
          }
        });
      });

      // Listeners eliminar
      document.querySelectorAll('.btn-delete-domain').forEach(el => {
        const btn = el as HTMLButtonElement;
        btn.addEventListener('click', async () => {
          const id = parseInt(btn.getAttribute('data-id') as string);
          const domain = btn.getAttribute('data-domain');

          const confirmed = await showConfirm({
            title: '¿Eliminar dominio?',
            text: `¿Deseas eliminar el dominio "${domain}"? Esta acción no se puede deshacer.`,
            confirmButtonText: 'Sí, eliminar',
            cancelButtonText: 'Cancelar',
          });

          if (confirmed) {
            btn.classList.add('loading');
            btn.disabled = true;
            try {
              await deleteDomain(id);
              showToast({ text: `Dominio "${domain}" eliminado.`, icon: 'success' });
              domainsLoaded = false;
              loadDomains();
            } catch (error: any) {
              showToast({ text: `Error: ${error.message}`, icon: 'error' });
              btn.classList.remove('loading');
              btn.disabled = false;
            }
          }
        });
      });
    }

    // Botón Nuevo Dominio
    const addDomainBtn = document.getElementById('add-domain-btn') as HTMLButtonElement;
    if (addDomainBtn) {
      addDomainBtn.addEventListener('click', async () => {
        const result: any = await showCreateDomainModal();
        if (result) {
          addDomainBtn.disabled = true;
          addDomainBtn.innerHTML = '<span class="spinner" style="width:20px;height:20px;border-width:2px;margin-right:8px;"></span> Guardando...';
          try {
            await addDomain(result.domain);
            showToast({ text: `Dominio "${result.domain}" agregado con éxito.`, icon: 'success' });
            domainsLoaded = false;
            loadDomains();
          } catch (error: any) {
            showToast({ text: `Error: ${error.message}`, icon: 'error' });
          } finally {
            addDomainBtn.disabled = false;
            addDomainBtn.innerHTML = `
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
              </svg>
              Nuevo Dominio
            `;
          }
        }
      });
    }
    // ──────────────────────────────────────────────────────────

    // ── Gestión de Cupones ──────────────────────────────────────
    const loadingStateCupons = document.getElementById('loading-state-cupons');
    const cuponsTable        = document.getElementById('cupons-table');
    const cuponsTbody        = document.getElementById('cupons-tbody');
    const emptyStateCupons   = document.getElementById('empty-state-cupons');
    const searchCuponInput   = document.getElementById('search-cupon') as HTMLInputElement;

    let allCupons: any[]    = [];
    let allCompanies: any[] = [];
    let editingCouponId: number | null = null;

    if (searchCuponInput) {
      searchCuponInput.addEventListener('input', () => {
        if (allCupons.length > 0) renderCupons(allCupons);
      });
    }

    async function loadCupons() {
      if (!loadingStateCupons || !cuponsTable || !emptyStateCupons) return;
      loadingStateCupons.style.display = 'flex';
      cuponsTable.style.display = 'none';
      emptyStateCupons.style.display = 'none';
      try {
        allCupons = await getAdminCoupons();
        if (!allCupons.length) {
          emptyStateCupons.style.display = 'block';
        } else {
          renderCupons(allCupons);
          cuponsTable.style.display = 'table';
        }
      } catch (e: any) {
        emptyStateCupons.style.display = 'block';
        emptyStateCupons.innerHTML = `<p>Error al cargar cupones: ${e.message}</p>`;
      } finally {
        loadingStateCupons.style.display = 'none';
      }
    }

    function renderCupons(cupons: any[]) {
      if (!cuponsTbody) return;
      const q = (searchCuponInput?.value || '').toLowerCase();
      const filtered = cupons.filter((c: any) =>
        (c.title || '').toLowerCase().includes(q) ||
        (c.companies?.name || '').toLowerCase().includes(q)
      );
      cuponsTbody.innerHTML = '';
      if (!filtered.length) {
        cuponsTbody.innerHTML = '<tr><td colspan="6" style="text-align:center;padding:3rem;color:#64748b;">No se encontraron cupones.</td></tr>';
        return;
      }
      filtered.forEach((c: any) => {
        const co = c.companies ?? {};
        const tr = document.createElement('tr');
        tr.innerHTML = `
          <td data-label="Empresa">
            <div style="display:flex;align-items:center;gap:0.7rem;">
              ${co.logo_url ? `<img src="${co.logo_url}" alt="" style="width:36px;height:36px;object-fit:contain;border-radius:8px;border:1px solid #e2e8f0;background:#f8fafc;padding:3px;">` : ''}
              <span class="text-gray" style="font-size:0.85rem;">${co.name || '—'}</span>
            </div>
          </td>
          <td data-label="Título"><span class="font-medium" style="font-size:0.95rem;">${c.title || '—'}</span></td>
          <td data-label="Vigencia"><span class="text-gray" style="font-size:0.85rem;">${c.vigencia || '—'}</span></td>
          <td data-label="Tipo"><span class="text-gray" style="font-size:0.85rem;">${c.tipo_descuento || '—'}</span></td>
          <td data-label="Estado" style="text-align:center;">
            <button class="cm-status-btn ${c.active ? 'active' : 'inactive'}" data-id="${c.id}" data-active="${c.active}" title="${c.active ? 'Desactivar' : 'Activar'}">
              ${c.active ? 'Activo' : 'Inactivo'}
            </button>
          </td>
          <td data-label="Acciones" class="actions-cell">
            <div style="display:flex;gap:0.5rem;justify-content:flex-end;">
              <button class="btn-icon btn-edit-cupon" data-id="${c.id}" title="Editar cupón">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
              </button>
              <button class="btn-icon btn-delete-cupon" data-id="${c.id}" data-title="${(c.title || '').replace(/"/g, '&quot;')}" title="Eliminar cupón">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
              </button>
            </div>
          </td>
        `;
        cuponsTbody.appendChild(tr);
      });

      // Toggle activo/inactivo
      cuponsTbody.querySelectorAll('.cm-status-btn').forEach(el => {
        el.addEventListener('click', async () => {
          const btn     = el as HTMLButtonElement;
          const id      = parseInt(btn.getAttribute('data-id')!);
          const current = btn.getAttribute('data-active') === 'true';
          btn.disabled  = true;
          try {
            await toggleCouponActive(id, !current);
            showToast({ text: `Cupón ${!current ? 'activado' : 'desactivado'} correctamente.`, icon: 'success' });
            cuponesLoaded = false; loadCupons();
          } catch (e: any) {
            showToast({ text: `Error: ${e.message}`, icon: 'error' });
            btn.disabled = false;
          }
        });
      });

      // Eliminar
      cuponsTbody.querySelectorAll('.btn-delete-cupon').forEach(el => {
        el.addEventListener('click', async () => {
          const btn   = el as HTMLButtonElement;
          const id    = parseInt(btn.getAttribute('data-id')!);
          const title = btn.getAttribute('data-title');
          const ok    = await showConfirm({
            title: '¿Eliminar cupón?',
            text: `¿Deseas eliminar permanentemente el cupón "${title}"?`,
            confirmButtonText: 'Sí, eliminar',
            cancelButtonText: 'Cancelar',
          });
          if (!ok) return;
          btn.classList.add('loading'); btn.disabled = true;
          try {
            await deleteCoupon(id);
            showToast({ text: 'Cupón eliminado correctamente.', icon: 'success' });
            cuponesLoaded = false; loadCupons();
          } catch (e: any) {
            showToast({ text: `Error: ${e.message}`, icon: 'error' });
            btn.classList.remove('loading'); btn.disabled = false;
          }
        });
      });

      // Editar
      cuponsTbody.querySelectorAll('.btn-edit-cupon').forEach(el => {
        el.addEventListener('click', () => {
          const id  = parseInt((el as HTMLButtonElement).getAttribute('data-id')!);
          const c   = allCupons.find((x: any) => x.id === id);
          if (c) openCouponModal(c);
        });
      });
    }

    // ── Modal Cupón ─────────────────────────────────────────────
    const cmOverlay       = document.getElementById('cm-overlay');
    const cmModalTitle    = document.getElementById('cm-modal-title');
    const cmCompanyId     = document.getElementById('cm-company-id')     as HTMLSelectElement;
    const cmSortOrder     = document.getElementById('cm-sort-order')     as HTMLInputElement;
    const cmActiveChk     = document.getElementById('cm-active')         as HTMLInputElement;
    const cmActiveLabel   = document.getElementById('cm-active-label');
    const cmTitleInput    = document.getElementById('cm-title')          as HTMLInputElement;
    const cmDescription   = document.getElementById('cm-description')   as HTMLTextAreaElement;
    const cmVigencia      = document.getElementById('cm-vigencia')       as HTMLInputElement;
    const cmTipoDesc      = document.getElementById('cm-tipo-descuento') as HTMLSelectElement;
    const cmDiscountAmt   = document.getElementById('cm-discount-amount') as HTMLInputElement;
    const cmDiscountLbl   = document.getElementById('cm-discount-label') as HTMLInputElement;
    const cmCodeLabel     = document.getElementById('cm-code-label')    as HTMLInputElement;
    const cmDiscountCode  = document.getElementById('cm-discount-code') as HTMLInputElement;
    const cmBenefitText   = document.getElementById('cm-benefit-text')  as HTMLTextAreaElement;
    const cmTerms         = document.getElementById('cm-terms')         as HTMLTextAreaElement;
    const cmSaveBtn       = document.getElementById('cm-save-btn')      as HTMLButtonElement;
    const cmCancelBtn     = document.getElementById('cm-cancel-btn')    as HTMLButtonElement;
    const cmCloseBtn      = document.getElementById('cm-close-btn')     as HTMLButtonElement;

    // Toggle label en tiempo real
    if (cmActiveChk && cmActiveLabel) {
      cmActiveChk.addEventListener('change', () => {
        cmActiveLabel.textContent = cmActiveChk.checked ? 'Activo (visible en home)' : 'Inactivo (oculto en home)';
      });
    }

    function closeCouponModal() {
      if (cmOverlay) cmOverlay.style.display = 'none';
      document.body.style.overflow = '';
      editingCouponId = null;
    }

    async function populateCompanies() {
      if (!cmCompanyId) return;
      if (!allCompanies.length) {
        try { allCompanies = await getCompaniesForSelect(); } catch { allCompanies = []; }
      }
      const currentVal = cmCompanyId.value;
      cmCompanyId.innerHTML = '<option value="">— Selecciona una empresa —</option>' +
        allCompanies.map((co: any) => `<option value="${co.id}">${co.name}</option>`).join('');
      if (currentVal) cmCompanyId.value = currentVal;
    }

    async function openCouponModal(coupon: any = null) {
      editingCouponId = coupon ? coupon.id : null;
      if (cmModalTitle) cmModalTitle.textContent = coupon ? 'Editar Cupón' : 'Nuevo Cupón';
      await populateCompanies();

      // Llenar o limpiar campos
      if (cmCompanyId)    cmCompanyId.value    = coupon?.company_id    ?? '';
      if (cmSortOrder)    cmSortOrder.value    = coupon?.sort_order    ?? '0';
      if (cmActiveChk)  { cmActiveChk.checked  = coupon ? coupon.active : true; }
      if (cmActiveLabel)  cmActiveLabel.textContent = (coupon ? coupon.active : true) ? 'Activo (visible en home)' : 'Inactivo (oculto en home)';
      if (cmTitleInput)   cmTitleInput.value   = coupon?.title         ?? '';
      if (cmDescription)  cmDescription.value  = coupon?.description   ?? '';
      if (cmVigencia)     cmVigencia.value      = coupon?.vigencia      ?? '';
      if (cmTipoDesc)     cmTipoDesc.value      = coupon?.tipo_descuento ?? 'Descuento porcentual';
      if (cmDiscountAmt)  cmDiscountAmt.value   = coupon?.discount_amount ?? 'XXXX';
      if (cmDiscountLbl)  cmDiscountLbl.value   = coupon?.discount_label  ?? 'DE DESCUENTO';
      if (cmCodeLabel)    cmCodeLabel.value     = coupon?.code_label      ?? 'Usando el código';
      if (cmDiscountCode) cmDiscountCode.value  = coupon?.discount_code   ?? 'XXXXXXXXXX';
      if (cmBenefitText)  cmBenefitText.value   = coupon?.benefit_text    ?? '';
      if (cmTerms)        cmTerms.value         = coupon?.terms           ?? '';

      if (cmOverlay) cmOverlay.style.display = 'flex';
      document.body.style.overflow = 'hidden';
      cmTitleInput?.focus();
    }

    async function saveCoupon() {
      if (!cmTitleInput?.value.trim()) {
        showToast({ text: 'El título es obligatorio.', icon: 'error' }); return;
      }
      if (!cmCompanyId?.value) {
        showToast({ text: 'Debes seleccionar una empresa.', icon: 'error' }); return;
      }

      const payload = {
        company_id:      parseInt(cmCompanyId.value),
        sort_order:      parseInt(cmSortOrder?.value || '0'),
        active:          cmActiveChk?.checked ?? true,
        title:           cmTitleInput.value.trim(),
        description:     cmDescription?.value  ?? '',
        vigencia:        cmVigencia?.value      ?? '',
        tipo_descuento:  cmTipoDesc?.value      ?? '',
        discount_amount: cmDiscountAmt?.value   || 'XXXX',
        discount_label:  cmDiscountLbl?.value   || 'DE DESCUENTO',
        code_label:      cmCodeLabel?.value     || 'Usando el código',
        discount_code:   cmDiscountCode?.value  || 'XXXXXXXXXX',
        benefit_text:    cmBenefitText?.value   ?? '',
        terms:           cmTerms?.value         ?? '',
      };

      if (cmSaveBtn) { cmSaveBtn.disabled = true; cmSaveBtn.textContent = 'Guardando...'; }
      try {
        if (editingCouponId) {
          await updateCoupon(editingCouponId, payload);
          showToast({ text: 'Cupón actualizado correctamente.', icon: 'success' });
        } else {
          await createCoupon(payload);
          showToast({ text: 'Cupón creado correctamente.', icon: 'success' });
        }
        closeCouponModal();
        cuponesLoaded = false; loadCupons();
      } catch (e: any) {
        showToast({ text: `Error: ${e.message}`, icon: 'error' });
      } finally {
        if (cmSaveBtn) {
          cmSaveBtn.disabled = false;
          cmSaveBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg> Guardar Cupón`;
        }
      }
    }

    [cmCloseBtn, cmCancelBtn].forEach(btn => btn?.addEventListener('click', closeCouponModal));
    cmOverlay?.addEventListener('click', (e) => { if (e.target === cmOverlay) closeCouponModal(); });
    cmSaveBtn?.addEventListener('click', saveCoupon);
    document.getElementById('add-cupon-btn')?.addEventListener('click', () => openCouponModal());
    // ──────────────────────────────────────────────────────────

    // Inicialización y verificación de seguridad
    async function init() {
      try {
        const profile = await getUserProfile();
        
        if (!profile || profile.role !== 'admin') {
          // Redirigir si no es admin o no está logueado
          window.location.href = "/home";
          return;
        }

        // Si es admin, cargar la tabla
