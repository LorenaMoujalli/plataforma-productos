---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Administración de Usuarios - Oberstaff">
  <div class="admin-container">
    <div class="admin-header">
      <div>
        <h1>Panel de Administración</h1>
        <p>Gestiona los usuarios de la plataforma.</p>
      </div>
      <button id="add-user-btn" class="btn-success">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="12" y1="5" x2="12" y2="19"></line>
          <line x1="5" y1="12" x2="19" y2="12"></line>
        </svg>
        Nuevo Usuario
      </button>
    </div>

    <!-- Mensajes de estado -->
    <div id="status-message" class="status-message" style="display: none;"></div>

    <div class="table-container">
      <div id="loading-state" class="loading-state">
        <div class="spinner"></div>
        <p>Cargando usuarios...</p>
      </div>

      <table id="users-table" class="users-table" style="display: none;">
        <thead>
          <tr>
            <th>Nombre</th>
            <th>Correo Electrónico</th>
            <th>Rol</th>
            <th>Fecha de Registro</th>
            <th class="text-right">Acciones</th>
          </tr>
        </thead>
        <tbody id="users-tbody">
          <!-- Las filas se renderizarán dinámicamente aquí -->
        </tbody>
      </table>
      
      <div id="empty-state" class="empty-state" style="display: none;">
        <p>No se encontraron usuarios o hubo un error al cargar los datos.</p>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  import { getUserProfile, getAdminUsers, deleteAdminUser, adminCreateUser, adminUpdateUser } from "../../services/auth.js";
  import { showConfirm, showToast, showCreateUserModal, showEditUserModal } from "../../utils/notifications.js";

  function setupDashboard() {
    // Solo ejecutar en la ruta del dashboard
    if (!window.location.pathname.includes('/admin/dashboard')) return;

    // Elementos del DOM
    const loadingState = document.getElementById("loading-state");
    const usersTable = document.getElementById("users-table");
    const usersTbody = document.getElementById("users-tbody");
    const emptyState = document.getElementById("empty-state");
    const statusMessage = document.getElementById("status-message");

    // Mostrar mensajes
    function showMessage(msg: string, type: string = "success") {
      if (!statusMessage) return;
      statusMessage.textContent = msg;
      statusMessage.className = `status-message ${type}`;
      statusMessage.style.display = "block";
      
      // Ocultar después de 4 segundos
      setTimeout(() => {
        statusMessage.style.display = "none";
      }, 4000);
    }

    // Formatear fecha
    function formatDate(dateString: string | Date | null | undefined) {
      if (!dateString) return "N/A";
      const options: Intl.DateTimeFormatOptions = { year: 'numeric', month: 'short', day: 'numeric' };
      return new Date(dateString).toLocaleDateString('es-ES', options);
    }

    // Cargar usuarios
    async function loadUsers() {
      if (!loadingState || !usersTable || !emptyState) return;
      
      try {
        loadingState.style.display = "flex";
        usersTable.style.display = "none";
        emptyState.style.display = "none";

        const users = await getAdminUsers();

        if (!users || users.length === 0) {
          emptyState.style.display = "block";
        } else {
          renderUsers(users);
          usersTable.style.display = "table";
        }
      } catch (error) {
        console.error("Error al cargar usuarios:", error);
        emptyState.style.display = "block";
        emptyState.innerHTML = `<p>Error al cargar usuarios. Verifica que tienes permisos de administrador.</p>`;
      } finally {
        loadingState.style.display = "none";
      }
    }

    // Renderizar filas de usuarios
    function renderUsers(users: any[]) {
      if (!usersTbody) return;
      usersTbody.innerHTML = "";
      
      users.forEach((user: any) => {
        const tr = document.createElement("tr");
        
        // Estilo especial para admin badge
        const roleBadge = user.role === 'admin' 
          ? `<span class="badge badge-admin">Admin</span>` 
          : `<span class="badge badge-user">Usuario</span>`;

        tr.innerHTML = `
          <td data-label="Nombre">
            <div class="user-info">
              <span class="font-medium">${user.name || 'Sin nombre'}</span>
            </div>
          </td>
          <td data-label="Correo"><span class="text-gray">${user.email}</span></td>
          <td data-label="Rol">${roleBadge}</td>
          <td data-label="Fecha Registro"><span class="text-gray">${formatDate(user.created_at)}</span></td>
          <td data-label="Acciones" class="actions-cell">
            <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
              <button class="btn-icon btn-edit" data-user='${JSON.stringify({id: user.id, email: user.email, name: user.name, role: user.role}).replace(/'/g, "&apos;")}' title="Editar usuario">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                  <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                </svg>
              </button>
              ${user.role !== 'admin' ? `
                <button class="btn-icon btn-delete" data-id="${user.id}" data-email="${user.email}" title="Eliminar usuario">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="3 6 5 6 21 6"></polyline>
                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                    <line x1="10" y1="11" x2="10" y2="17"></line>
                    <line x1="14" y1="11" x2="14" y2="17"></line>
                  </svg>
                </button>
              ` : '<span class="text-muted text-sm" style="display: flex; align-items: center;">No eliminable</span>'}
            </div>
          </td>
        `;
        
        usersTbody.appendChild(tr);
      });

      // Agregar event listeners a los botones de eliminar
      document.querySelectorAll('.btn-delete').forEach(element => {
        const btn = element as HTMLButtonElement;
        btn.addEventListener('click', async (e) => {
          const userId = btn.getAttribute('data-id') as string;
          const userEmail = btn.getAttribute('data-email');
          
          const isConfirmed = await showConfirm({
            title: "¿Estás seguro?",
            text: `¿Deseas eliminar permanentemente al usuario ${userEmail}? Esta acción no se puede deshacer.`,
            confirmButtonText: "Sí, eliminar",
            cancelButtonText: "Cancelar"
          });

          if (isConfirmed) {
            btn.classList.add('loading');
            btn.disabled = true;
            
            try {
              await deleteAdminUser(userId);
              showToast({ text: `El usuario ${userEmail} ha sido eliminado.`, icon: 'success' });
              loadUsers(); // Recargar la tabla
            } catch (error: any) {
              console.error("Error eliminando usuario:", error);
              showToast({ text: `Hubo un error al eliminar el usuario: ${error.message}`, icon: 'error' });
              btn.classList.remove('loading');
              btn.disabled = false;
            }
          }
        });
      });

      // Agregar event listeners a los botones de editar
      document.querySelectorAll('.btn-edit').forEach(element => {
        const btn = element as HTMLButtonElement;
        btn.addEventListener('click', async () => {
          const userDataRaw = btn.getAttribute('data-user');
          if (!userDataRaw) return;
          
          const user = JSON.parse(userDataRaw);
          const newValues: any = await showEditUserModal(user);
          
          if (newValues) {
            btn.classList.add('loading');
            try {
              await adminUpdateUser(user.id, newValues.name, newValues.role);
              showToast({ text: `Usuario actualizado correctamente.`, icon: 'success' });
              loadUsers();
            } catch (error: any) {
              console.error("Error actualizando usuario:", error);
              
              // Si falla por RLS, mostrar mensaje amigable
              if (error.message.includes("Row Level Security") || error.message.includes("RLS") || error.message.includes("not allowed")) {
                showToast({ text: `Necesitamos crear un permiso SQL (RPC) para actualizar perfiles.`, icon: 'error' });
              } else {
                showToast({ text: `Error: ${error.message}`, icon: 'error' });
              }
              btn.classList.remove('loading');
            }
          }
        });
      });
    }

    // Configurar botón de Nuevo Usuario
    const addUserBtn = document.getElementById('add-user-btn') as HTMLButtonElement;
    if (addUserBtn) {
      addUserBtn.addEventListener('click', async () => {
        const userData: any = await showCreateUserModal();
        if (userData) {
          try {
            addUserBtn.disabled = true;
            addUserBtn.innerHTML = '<span class="spinner" style="width:20px;height:20px;border-width:2px;margin-right:8px;"></span> Registrando...';
            
            await adminCreateUser(userData.email, userData.password, userData.name, userData.role);
            
            showToast({ text: `Usuario ${userData.email} creado con éxito.`, icon: 'success' });
            loadUsers(); // Recargar la tabla
          } catch (error: any) {
            console.error("Error creando usuario:", error);
            showToast({ text: `Error: ${error.message}`, icon: 'error' });
          } finally {
            addUserBtn.disabled = false;
            addUserBtn.innerHTML = `
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
              </svg>
              Nuevo Usuario
            `;
          }
        }
      });
    }

    // Inicialización y verificación de seguridad
    async function init() {
      try {
        const profile = await getUserProfile();
        
        if (!profile || profile.role !== 'admin') {
          // Redirigir si no es admin o no está logueado
          window.location.href = "/home";
          return;
        }

        // Si es admin, cargar la tabla
        loadUsers();
      } catch (error) {
        console.error("Error en inicialización del dashboard:", error);
        window.location.href = "/login";
      }
    }

    // Arrancar
    init();
  }

  // Ejecutar al cargar la página
  setupDashboard();
</script>

<style is:global>
  .admin-container {
    width: 100%;
    max-width: 100%; /* Ocupará todo el ancho disponible */
    margin: 0 auto;
    padding: 2rem 5%; /* Un poco de margen a los lados */
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
  }

  .admin-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    padding: 1rem 0; /* Removido el padding grueso */
    background: transparent; /* Fondo blanco/transparente */
    color: #0f172a; /* Texto oscuro de nuevo */
    border-radius: 0;
    box-shadow: none; /* Sin sombra en el header */
  }

  .admin-header h1 {
    font-size: 2.2rem;
    font-weight: 800;
    margin: 0 0 0.5rem 0;
    letter-spacing: -0.5px;
    color: #0f172a;
  }

  .admin-header p {
    color: #64748b;
    margin: 0;
    font-size: 1.1rem;
    font-weight: 400;
  }

  .btn-success {
    background-color: #10b981;
    color: white;
    border: none;
    border-radius: 12px;
    padding: 0.9rem 1.8rem;
    font-weight: 600;
    font-size: 1.05rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 8px 20px rgba(16, 185, 129, 0.3);
    position: relative;
    z-index: 1;
  }

  .btn-success:hover {
    background-color: #059669;
    transform: translateY(-3px);
    box-shadow: 0 12px 24px rgba(16, 185, 129, 0.4);
  }

  .status-message {
    padding: 1.2rem 2rem;
    border-radius: 12px;
    margin-bottom: 2rem;
    font-weight: 600;
    font-size: 1.05rem;
    animation: fadeIn 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
  }

  .status-message.success {
    background-color: #ecfdf5;
    color: #047857;
    border: 1px solid #a7f3d0;
    border-left: 5px solid #10b981;
  }

  .status-message.error {
    background-color: #fef2f2;
    color: #b91c1c;
    border: 1px solid #fecaca;
    border-left: 5px solid #ef4444;
  }

  .table-container {
    background-color: white;
    border-radius: 20px;
    box-shadow: 0 15px 50px rgba(0, 0, 0, 0.08);
    border: 1px solid #f1f5f9;
    overflow: hidden;
  }

  .users-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    text-align: left;
  }

  .users-table th {
    background-color: #f8fafc;
    padding: 1.5rem 2rem;
    font-size: 0.95rem;
    font-weight: 700;
    color: #334155;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 2px solid #e2e8f0;
  }

  .users-table td {
    padding: 1.5rem 2rem;
    border-bottom: 1px solid #f1f5f9;
    vertical-align: middle;
    font-size: 1.05rem;
  }

  .users-table tbody tr {
    transition: all 0.25s ease;
    background-color: white;
  }

  .users-table tbody tr:hover {
    background-color: #fefeff;
    box-shadow: 0 4px 15px rgba(0,0,0,0.03);
    transform: scale(1.001) translateY(-1px);
    position: relative;
    z-index: 10;
  }

  .users-table tbody tr:last-child td {
    border-bottom: none;
  }

  .user-info {
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }

  .avatar {
    width: 50px;
    height: 50px;
    border-radius: 14px;
    background: linear-gradient(135deg, #da291c 0%, #a21c13 100%);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.4rem;
    box-shadow: 0 8px 16px rgba(218, 41, 28, 0.25);
  }

  /* Si quieres avatares azules para usuarios normales, se puede cambiar en JS, pero rojo es tu marca */

  .font-medium {
    font-weight: 700;
    color: #0f172a;
    font-size: 1.15rem;
  }

  .text-gray {
    color: #475569;
    font-weight: 500;
  }

  .text-muted {
    color: #94a3b8;
    font-weight: 500;
  }

  .text-sm {
    font-size: 0.9rem;
  }

  .text-right {
    text-align: right;
  }

  .actions-cell {
    text-align: right;
  }

  .badge {
    padding: 0.45rem 1.2rem;
    border-radius: 9999px;
    font-size: 0.85rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: inline-block;
  }

  .badge-admin {
    background-color: #f8fafc;
    color: #475569;
    border: 1px solid #e2e8f0;
    box-shadow: none;
  }

  .badge-user {
    background-color: transparent;
    color: #475569;
    border: 1px solid transparent;
    box-shadow: none;
  }

  .btn-icon {
    background: #f1f5f9;
    border: 1px solid #e2e8f0;
    color: #64748b;
    cursor: pointer;
    padding: 0.7rem;
    border-radius: 10px;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .btn-delete:hover {
    background-color: #fee2e2;
    color: #ef4444;
    border-color: #fecaca;
    transform: scale(1.1) rotate(2deg);
    box-shadow: 0 4px 10px rgba(239, 68, 68, 0.2);
  }

  .btn-edit:hover {
    background-color: #e0f2fe;
    color: #0284c7;
    border-color: #bae6fd;
    transform: scale(1.1);
    box-shadow: 0 4px 10px rgba(2, 132, 199, 0.2);
  }

  .btn-delete.loading, .btn-edit.loading {
    opacity: 0.5;
    cursor: not-allowed;
    transform: scale(1);
  }

  .loading-state, .empty-state {
    padding: 6rem 2rem;
    text-align: center;
    color: #64748b;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    font-size: 1.1rem;
  }

  .spinner {
    width: 50px;
    height: 50px;
    border: 4px solid #f1f5f9;
    border-top-color: #da291c;
    border-radius: 50%;
    animation: spin 1s cubic-bezier(0.68, -0.55, 0.265, 1.55) infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-15px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .admin-container {
      padding: 1.5rem 1rem;
    }
    
    .admin-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
      padding: 1.5rem;
    }
    
    .admin-header h1 {
      font-size: 1.8rem;
    }
    
    .users-table, .users-table tbody, .users-table tr, .users-table td {
      display: block;
      width: 100%;
    }
    
    .users-table thead {
      display: none;
    }
    
    .users-table tr {
      margin-bottom: 1.5rem;
      border: 1px solid #e2e8f0;
      border-radius: 12px;
      background-color: #ffffff;
      box-shadow: 0 4px 10px rgba(0,0,0,0.03);
    }
    
    .users-table td {
      text-align: right;
      padding: 1.2rem;
      position: relative;
      border-bottom: 1px solid #f1f5f9;
    }
    
    .users-table td:last-child {
      border-bottom: none;
    }
    
    .users-table td::before {
      content: attr(data-label);
      position: absolute;
      left: 1.2rem;
      top: 50%;
      transform: translateY(-50%);
      font-weight: 700;
      color: #64748b;
      font-size: 0.85rem;
      text-transform: uppercase;
    }
    
    .user-info {
      justify-content: flex-end;
    }
  }
</style>
