---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Administración de Usuarios - Oberstaff">
  <div class="admin-container">
    <a href="/home" class="back-link">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="19" y1="12" x2="5" y2="12"></line>
        <polyline points="12 19 5 12 12 5"></polyline>
      </svg>
      Volver
    </a>

    <div class="admin-header">
      <div class="header-titles">
        <div class="title-row">
          <h1>Panel de Administración</h1>
          <div class="admin-tabs">
            <button class="tab-btn tab-active" data-tab="usuarios">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
              </svg>
              Usuarios
            </button>
            <button class="tab-btn" data-tab="dominios">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="2" y1="12" x2="22" y2="12"></line>
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
              </svg>
              Dominios
            </button>
            <button class="tab-btn" data-tab="cupon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                <line x1="7" y1="7" x2="7.01" y2="7"></line>
              </svg>
              Cupón
            </button>
          </div>
        </div>
        <p id="tab-subtitle">Gestiona los usuarios de la plataforma.</p>
      </div>
      <!-- Acciones tab Usuarios -->
      <div class="header-actions" id="usuarios-actions">
        <div class="search-box">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          <input type="text" id="search-user" placeholder="Buscar por nombre o correo...">
        </div>
        <button id="add-user-btn" class="btn-success">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
          </svg>
          Nuevo Usuario
        </button>
      </div>

      <!-- Acciones tab Dominios -->
      <div class="header-actions" id="dominios-actions" style="display:none;">
        <div class="search-box">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          <input type="text" id="search-domain" placeholder="Buscar dominio...">
        </div>
        <button id="add-domain-btn" class="btn-success">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
          </svg>
          Nuevo Dominio
        </button>
      </div>
    </div>

    <!-- Mensajes de estado -->
    <div id="status-message" class="status-message" style="display: none;"></div>

    <!-- Panel: Usuarios -->
    <div id="panel-usuarios" class="tab-panel">
      <div class="table-container">
        <div id="loading-state" class="loading-state">
          <div class="spinner"></div>
          <p>Cargando usuarios...</p>
        </div>

        <table id="users-table" class="users-table" style="display: none;">
          <thead>
            <tr>
              <th>Nombre</th>
              <th>Correo Electrónico</th>
              <th>Rol</th>
              <th>Fecha de Registro</th>
              <th class="text-right">Acciones</th>
            </tr>
          </thead>
          <tbody id="users-tbody">
            <!-- Las filas se renderizarán dinámicamente aquí -->
          </tbody>
        </table>

        <div id="empty-state" class="empty-state" style="display: none;">
          <p>No se encontraron usuarios o hubo un error al cargar los datos.</p>
        </div>
      </div>
    </div>

    <!-- Panel: Dominios -->
    <div id="panel-dominios" class="tab-panel" style="display:none;">
      <div class="table-container">
        <div id="loading-state-domains" class="loading-state">
          <div class="spinner"></div>
          <p>Cargando dominios...</p>
        </div>

        <table id="domains-table" class="users-table" style="display: none;">
          <thead>
            <tr>
              <th>Dominio</th>
              <th>Fecha de Registro</th>
              <th class="text-right">Acciones</th>
            </tr>
          </thead>
          <tbody id="domains-tbody">
          </tbody>
        </table>

        <div id="empty-state-domains" class="empty-state" style="display: none;">
          <p>No hay dominios registrados aún.</p>
        </div>
      </div>
    </div>

    <!-- Panel: Cupón -->
    <div id="panel-cupon" class="tab-panel" style="display:none;">
      <div class="placeholder-panel">
        <div class="placeholder-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#cbd5e1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
            <line x1="7" y1="7" x2="7.01" y2="7"></line>
          </svg>
        </div>
        <h2>Gestión de Cupones</h2>
        <p>Aquí podrás crear y administrar los cupones de descuento.</p>
        <span class="coming-soon-badge">Próximamente</span>
      </div>
    </div>

  </div>
</DashboardLayout>

<script>
  import { getUserProfile, getAdminUsers, deleteAdminUser, adminCreateUser, adminUpdateUser } from "../../services/auth.js";
  import { getDomains, addDomain, updateDomain, deleteDomain, getAllowedDomainNames } from "../../services/domains.js";
  import { showConfirm, showToast, showCreateUserModal, showEditUserModal, showCreateDomainModal, showEditDomainModal } from "../../utils/notifications.js";

  function setupDashboard() {
    // Solo ejecutar en la ruta del dashboard
    if (!window.location.pathname.includes('/admin/dashboard')) return;

    // Dominios permitidos (para pasarlos a los modales de usuario)
    let allowedDomains: string[] = [];
    getAllowedDomainNames().then(d => { allowedDomains = d; }).catch(() => {});

    // Elementos del DOM
    const loadingState = document.getElementById("loading-state");
    const usersTable = document.getElementById("users-table");
    const usersTbody = document.getElementById("users-tbody");
    const emptyState = document.getElementById("empty-state");
    const statusMessage = document.getElementById("status-message");
    const searchInput = document.getElementById("search-user") as HTMLInputElement;

    let allUsers: any[] = []; // Guardamos los usuarios globalmente para filtrarlos

    // ── Tab switching ──────────────────────────────────────────
    const tabBtns = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
    const tabPanels: Record<string, HTMLElement | null> = {
      usuarios: document.getElementById('panel-usuarios'),
      dominios: document.getElementById('panel-dominios'),
      cupon:    document.getElementById('panel-cupon'),
    };
    const usuariosActions = document.getElementById('usuarios-actions');
    const dominiosActions = document.getElementById('dominios-actions');
    const tabSubtitle = document.getElementById('tab-subtitle');

    const subtitles: Record<string, string> = {
      usuarios: 'Gestiona los usuarios de la plataforma.',
      dominios: 'Administra los dominios autorizados para registro.',
      cupon:    'Crea y gestiona cupones de descuento.',
    };

    let domainsLoaded = false;

    function switchTab(tab: string) {
      tabBtns.forEach(btn => btn.classList.remove('tab-active'));
      const activeBtn = document.querySelector<HTMLButtonElement>(`.tab-btn[data-tab="${tab}"]`);
      if (activeBtn) activeBtn.classList.add('tab-active');

      Object.entries(tabPanels).forEach(([key, panel]) => {
        if (panel) panel.style.display = key === tab ? 'block' : 'none';
      });

      if (usuariosActions) usuariosActions.style.display = tab === 'usuarios' ? 'flex' : 'none';
      if (dominiosActions) dominiosActions.style.display = tab === 'dominios' ? 'flex' : 'none';

      if (tabSubtitle) tabSubtitle.textContent = subtitles[tab] ?? '';

      // Cargar dominios la primera vez que se abre ese tab
      if (tab === 'dominios' && !domainsLoaded) {
        domainsLoaded = true;
        loadDomains();
      }
    }

    tabBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const tab = btn.getAttribute('data-tab');
        if (tab) switchTab(tab);
      });
    });
    // ──────────────────────────────────────────────────────────

    // Event listener para el buscador
    if (searchInput) {
      searchInput.addEventListener('input', () => {
        if (allUsers.length > 0) {
          renderUsers(allUsers);
        }
      });
    }

    // Mostrar mensajes
    function showMessage(msg: string, type: string = "success") {
      if (!statusMessage) return;
      statusMessage.textContent = msg;
      statusMessage.className = `status-message ${type}`;
      statusMessage.style.display = "block";
      
      // Ocultar después de 4 segundos
      setTimeout(() => {
        statusMessage.style.display = "none";
      }, 4000);
    }

    // Formatear fecha
    function formatDate(dateString: string | Date | null | undefined) {
      if (!dateString) return "N/A";
      const options: Intl.DateTimeFormatOptions = { year: 'numeric', month: 'short', day: 'numeric' };
      return new Date(dateString).toLocaleDateString('es-ES', options);
    }

    // Cargar usuarios
    async function loadUsers() {
      if (!loadingState || !usersTable || !emptyState) return;
      
      try {
        loadingState.style.display = "flex";
        usersTable.style.display = "none";
        emptyState.style.display = "none";

        const users = await getAdminUsers();

        if (!users || users.length === 0) {
          emptyState.style.display = "block";
        } else {
          allUsers = users;
          renderUsers(allUsers);
          usersTable.style.display = "table";
        }
      } catch (error) {
        console.error("Error al cargar usuarios:", error);
        emptyState.style.display = "block";
        emptyState.innerHTML = `<p>Error al cargar usuarios. Verifica que tienes permisos de administrador.</p>`;
      } finally {
        loadingState.style.display = "none";
      }
    }

    // Renderizar filas de usuarios
    function renderUsers(users: any[]) {
      if (!usersTbody) return;
      usersTbody.innerHTML = "";
      
      const query = (searchInput?.value || "").toLowerCase().trim();
      const filteredUsers = users.filter((u: any) => {
        const nameMatch = (u.name || "").toLowerCase().includes(query);
        const emailMatch = (u.email || "").toLowerCase().includes(query);
        return nameMatch || emailMatch;
      });

      if (filteredUsers.length === 0) {
        usersTbody.innerHTML = '<tr><td colspan="5" style="text-align:center; padding:3rem; color:#64748b;">No se encontraron usuarios que coincidan con tu búsqueda.</td></tr>';
        return;
      }

      filteredUsers.forEach((user: any) => {
        const tr = document.createElement("tr");
        
        // Estilo especial para admin badge
        const roleBadge = user.role === 'admin' 
          ? `<span class="badge badge-admin">Admin</span>` 
          : `<span class="badge badge-user">Usuario</span>`;

        tr.innerHTML = `
          <td data-label="Nombre">
            <div class="user-info">
              <span class="font-medium">${user.name || 'Sin nombre'}</span>
            </div>
          </td>
          <td data-label="Correo"><span class="text-gray">${user.email}</span></td>
          <td data-label="Rol">${roleBadge}</td>
          <td data-label="Fecha Registro"><span class="text-gray">${formatDate(user.created_at)}</span></td>
          <td data-label="Acciones" class="actions-cell">
            <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
              <button class="btn-icon btn-edit" data-user='${JSON.stringify({id: user.id, email: user.email, name: user.name, role: user.role}).replace(/'/g, "&apos;")}' title="Editar usuario">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                  <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                </svg>
              </button>
              ${user.role !== 'admin' ? `
                <button class="btn-icon btn-delete" data-id="${user.id}" data-email="${user.email}" title="Eliminar usuario">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="3 6 5 6 21 6"></polyline>
                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                    <line x1="10" y1="11" x2="10" y2="17"></line>
                    <line x1="14" y1="11" x2="14" y2="17"></line>
                  </svg>
                </button>
              ` : '<span class="text-muted text-sm" style="display: flex; align-items: center;">No eliminable</span>'}
            </div>
          </td>
        `;
        
        usersTbody.appendChild(tr);
      });

      // Agregar event listeners a los botones de eliminar
      document.querySelectorAll('.btn-delete').forEach(element => {
        const btn = element as HTMLButtonElement;
        btn.addEventListener('click', async (e) => {
          const userId = btn.getAttribute('data-id') as string;
          const userEmail = btn.getAttribute('data-email');
          
          const isConfirmed = await showConfirm({
            title: "¿Estás seguro?",
            text: `¿Deseas eliminar permanentemente al usuario ${userEmail}? Esta acción no se puede deshacer.`,
            confirmButtonText: "Sí, eliminar",
            cancelButtonText: "Cancelar"
          });

          if (isConfirmed) {
            btn.classList.add('loading');
            btn.disabled = true;
            
            try {
              await deleteAdminUser(userId);
              showToast({ text: `El usuario ${userEmail} ha sido eliminado.`, icon: 'success' });
              loadUsers(); // Recargar la tabla
            } catch (error: any) {
              console.error("Error eliminando usuario:", error);
              showToast({ text: `Hubo un error al eliminar el usuario: ${error.message}`, icon: 'error' });
              btn.classList.remove('loading');
              btn.disabled = false;
            }
          }
        });
      });

      // Agregar event listeners a los botones de editar
      document.querySelectorAll('.btn-edit').forEach(element => {
        const btn = element as HTMLButtonElement;
        btn.addEventListener('click', async () => {
          const userDataRaw = btn.getAttribute('data-user');
          if (!userDataRaw) return;
          
          const user = JSON.parse(userDataRaw);
          const newValues: any = await showEditUserModal(user, allowedDomains);
          
          if (newValues) {
            btn.classList.add('loading');
            try {
              await adminUpdateUser(user.id, newValues.name, newValues.role, newValues.email, newValues.password);
              showToast({ text: `Usuario actualizado correctamente.`, icon: 'success' });
              loadUsers();
            } catch (error: any) {
              console.error("Error actualizando usuario:", error);
              
              // Si falla por RLS, mostrar mensaje amigable
              if (error.message.includes("Row Level Security") || error.message.includes("RLS") || error.message.includes("not allowed")) {
                showToast({ text: `Necesitamos crear un permiso SQL (RPC) para actualizar perfiles.`, icon: 'error' });
              } else {
                showToast({ text: `Error: ${error.message}`, icon: 'error' });
              }
              btn.classList.remove('loading');
            }
          }
        });
      });
    }

    // Configurar botón de Nuevo Usuario
    const addUserBtn = document.getElementById('add-user-btn') as HTMLButtonElement;
    if (addUserBtn) {
      addUserBtn.addEventListener('click', async () => {
        const userData: any = await showCreateUserModal(allowedDomains);
        if (userData) {
          try {
            addUserBtn.disabled = true;
            addUserBtn.innerHTML = '<span class="spinner" style="width:20px;height:20px;border-width:2px;margin-right:8px;"></span> Registrando...';
            
            await adminCreateUser(userData.email, userData.password, userData.name, userData.role);
            
            showToast({ text: `Usuario ${userData.email} creado con éxito.`, icon: 'success' });
            loadUsers(); // Recargar la tabla
          } catch (error: any) {
            console.error("Error creando usuario:", error);
            showToast({ text: `Error: ${error.message}`, icon: 'error' });
          } finally {
            addUserBtn.disabled = false;
            addUserBtn.innerHTML = `
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
              </svg>
              Nuevo Usuario
            `;
          }
        }
      });
    }

    // ── Gestión de Dominios ──────────────────────────────────────
    const loadingStateDomains = document.getElementById("loading-state-domains");
    const domainsTable = document.getElementById("domains-table");
    const domainsTbody = document.getElementById("domains-tbody");
    const emptyStateDomains = document.getElementById("empty-state-domains");
    const searchDomainInput = document.getElementById("search-domain") as HTMLInputElement;

    let allDomains: any[] = [];

    if (searchDomainInput) {
      searchDomainInput.addEventListener('input', () => {
        if (allDomains.length > 0) renderDomains(allDomains);
      });
    }

    async function loadDomains() {
      if (!loadingStateDomains || !domainsTable || !emptyStateDomains) return;

      loadingStateDomains.style.display = "flex";
      domainsTable.style.display = "none";
      emptyStateDomains.style.display = "none";

      try {
        const domains = await getDomains();
        if (!domains || domains.length === 0) {
          emptyStateDomains.style.display = "block";
        } else {
          allDomains = domains;
          renderDomains(allDomains);
          domainsTable.style.display = "table";
        }
      } catch (error: any) {
        console.error("Error al cargar dominios:", error);
        emptyStateDomains.style.display = "block";
        emptyStateDomains.innerHTML = `<p>Error al cargar dominios: ${error.message}</p>`;
      } finally {
        loadingStateDomains.style.display = "none";
      }
    }

    function renderDomains(domains: any[]) {
      if (!domainsTbody) return;
      domainsTbody.innerHTML = "";

      const query = (searchDomainInput?.value || "").toLowerCase().trim();
      const filtered = domains.filter((d: any) =>
        (d.domain || "").toLowerCase().includes(query)
      );

      if (filtered.length === 0) {
        domainsTbody.innerHTML = '<tr><td colspan="3" style="text-align:center; padding:3rem; color:#64748b;">No se encontraron dominios.</td></tr>';
        return;
      }

      filtered.forEach((d: any) => {
        const tr = document.createElement("tr");
        tr.innerHTML = `
          <td data-label="Dominio">
            <div style="display:flex; align-items:center; gap:0.8rem;">
              <div style="width:36px;height:36px;border-radius:10px;background:#f1f5f9;border:1px solid #e2e8f0;display:flex;align-items:center;justify-content:center;">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#64748b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"></circle>
                  <line x1="2" y1="12" x2="22" y2="12"></line>
                  <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                </svg>
              </div>
              <span class="font-medium">${d.domain}</span>
            </div>
          </td>
          <td data-label="Fecha Registro"><span class="text-gray">${formatDate(d.created_at)}</span></td>
          <td data-label="Acciones" class="actions-cell">
            <div style="display:flex;gap:0.5rem;justify-content:flex-end;">
              <button class="btn-icon btn-edit-domain" data-id="${d.id}" data-domain="${d.domain}" title="Editar dominio">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                  <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                </svg>
              </button>
              <button class="btn-icon btn-delete-domain" data-id="${d.id}" data-domain="${d.domain}" title="Eliminar dominio">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="3 6 5 6 21 6"></polyline>
                  <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                  <line x1="10" y1="11" x2="10" y2="17"></line>
                  <line x1="14" y1="11" x2="14" y2="17"></line>
                </svg>
              </button>
            </div>
          </td>
        `;
        domainsTbody.appendChild(tr);
      });

      // Listeners editar
      document.querySelectorAll('.btn-edit-domain').forEach(el => {
        const btn = el as HTMLButtonElement;
        btn.addEventListener('click', async () => {
          const id = parseInt(btn.getAttribute('data-id') as string);
          const domain = btn.getAttribute('data-domain') as string;
          const result: any = await showEditDomainModal({ id, domain });
          if (result) {
            btn.classList.add('loading');
            try {
              await updateDomain(id, result.domain);
              showToast({ text: `Dominio actualizado correctamente.`, icon: 'success' });
              domainsLoaded = false;
              loadDomains();
            } catch (error: any) {
              showToast({ text: `Error: ${error.message}`, icon: 'error' });
              btn.classList.remove('loading');
            }
          }
        });
      });

      // Listeners eliminar
      document.querySelectorAll('.btn-delete-domain').forEach(el => {
        const btn = el as HTMLButtonElement;
        btn.addEventListener('click', async () => {
          const id = parseInt(btn.getAttribute('data-id') as string);
          const domain = btn.getAttribute('data-domain');

          const confirmed = await showConfirm({
            title: '¿Eliminar dominio?',
            text: `¿Deseas eliminar el dominio "${domain}"? Esta acción no se puede deshacer.`,
            confirmButtonText: 'Sí, eliminar',
            cancelButtonText: 'Cancelar',
          });

          if (confirmed) {
            btn.classList.add('loading');
            btn.disabled = true;
            try {
              await deleteDomain(id);
              showToast({ text: `Dominio "${domain}" eliminado.`, icon: 'success' });
              domainsLoaded = false;
              loadDomains();
            } catch (error: any) {
              showToast({ text: `Error: ${error.message}`, icon: 'error' });
              btn.classList.remove('loading');
              btn.disabled = false;
            }
          }
        });
      });
    }

    // Botón Nuevo Dominio
    const addDomainBtn = document.getElementById('add-domain-btn') as HTMLButtonElement;
    if (addDomainBtn) {
      addDomainBtn.addEventListener('click', async () => {
        const result: any = await showCreateDomainModal();
        if (result) {
          addDomainBtn.disabled = true;
          addDomainBtn.innerHTML = '<span class="spinner" style="width:20px;height:20px;border-width:2px;margin-right:8px;"></span> Guardando...';
          try {
            await addDomain(result.domain);
            showToast({ text: `Dominio "${result.domain}" agregado con éxito.`, icon: 'success' });
            domainsLoaded = false;
            loadDomains();
          } catch (error: any) {
            showToast({ text: `Error: ${error.message}`, icon: 'error' });
          } finally {
            addDomainBtn.disabled = false;
            addDomainBtn.innerHTML = `
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
              </svg>
              Nuevo Dominio
            `;
          }
        }
      });
    }
    // ──────────────────────────────────────────────────────────

    // Inicialización y verificación de seguridad
    async function init() {
      try {
        const profile = await getUserProfile();
        
        if (!profile || profile.role !== 'admin') {
          // Redirigir si no es admin o no está logueado
          window.location.href = "/home";
          return;
        }

        // Si es admin, cargar la tabla
        loadUsers();
      } catch (error) {
        console.error("Error en inicialización del dashboard:", error);
        window.location.href = "/login";
      }
    }

    // Arrancar
    init();
  }

  // Ejecutar al cargar la página
  setupDashboard();
</script>

