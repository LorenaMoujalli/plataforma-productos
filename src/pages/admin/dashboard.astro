---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Administración de Usuarios - Oberstaff">
  <div class="admin-container">
    <div class="admin-header">
      <div>
        <h1>Panel de Administración</h1>
        <p>Gestiona los usuarios de la plataforma.</p>
      </div>
      <button id="add-user-btn" class="btn-primary" onclick="alert('Próximamente: Crear usuarios desde el panel')">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="12" y1="5" x2="12" y2="19"></line>
          <line x1="5" y1="12" x2="19" y2="12"></line>
        </svg>
        Nuevo Usuario
      </button>
    </div>

    <!-- Mensajes de estado -->
    <div id="status-message" class="status-message" style="display: none;"></div>

    <div class="table-container">
      <div id="loading-state" class="loading-state">
        <div class="spinner"></div>
        <p>Cargando usuarios...</p>
      </div>

      <table id="users-table" class="users-table" style="display: none;">
        <thead>
          <tr>
            <th>Nombre</th>
            <th>Correo Electrónico</th>
            <th>Rol</th>
            <th>Fecha de Registro</th>
            <th class="text-right">Acciones</th>
          </tr>
        </thead>
        <tbody id="users-tbody">
          <!-- Las filas se renderizarán dinámicamente aquí -->
        </tbody>
      </table>
      
      <div id="empty-state" class="empty-state" style="display: none;">
        <p>No se encontraron usuarios o hubo un error al cargar los datos.</p>
      </div>
    </div>
  </div>
</DashboardLayout>

<script>
  import { getUserProfile, getAdminUsers, deleteAdminUser } from "../../services/auth.js";

  function setupDashboard() {
    // Solo ejecutar en la ruta del dashboard
    if (!window.location.pathname.includes('/admin/dashboard')) return;

    // Elementos del DOM
    const loadingState = document.getElementById("loading-state");
    const usersTable = document.getElementById("users-table");
    const usersTbody = document.getElementById("users-tbody");
    const emptyState = document.getElementById("empty-state");
    const statusMessage = document.getElementById("status-message");

    // Mostrar mensajes
    function showMessage(msg: string, type: string = "success") {
      if (!statusMessage) return;
      statusMessage.textContent = msg;
      statusMessage.className = `status-message ${type}`;
      statusMessage.style.display = "block";
      
      // Ocultar después de 4 segundos
      setTimeout(() => {
        statusMessage.style.display = "none";
      }, 4000);
    }

    // Formatear fecha
    function formatDate(dateString: string | Date | null | undefined) {
      if (!dateString) return "N/A";
      const options: Intl.DateTimeFormatOptions = { year: 'numeric', month: 'short', day: 'numeric' };
      return new Date(dateString).toLocaleDateString('es-ES', options);
    }

    // Cargar usuarios
    async function loadUsers() {
      if (!loadingState || !usersTable || !emptyState) return;
      
      try {
        loadingState.style.display = "flex";
        usersTable.style.display = "none";
        emptyState.style.display = "none";

        const users = await getAdminUsers();

        if (!users || users.length === 0) {
          emptyState.style.display = "block";
        } else {
          renderUsers(users);
          usersTable.style.display = "table";
        }
      } catch (error) {
        console.error("Error al cargar usuarios:", error);
        emptyState.style.display = "block";
        emptyState.innerHTML = `<p>Error al cargar usuarios. Verifica que tienes permisos de administrador.</p>`;
      } finally {
        loadingState.style.display = "none";
      }
    }

    // Renderizar filas de usuarios
    function renderUsers(users: any[]) {
      if (!usersTbody) return;
      usersTbody.innerHTML = "";
      
      users.forEach((user: any) => {
        const tr = document.createElement("tr");
        
        // Estilo especial para admin badge
        const roleBadge = user.role === 'admin' 
          ? `<span class="badge badge-admin">Admin</span>` 
          : `<span class="badge badge-user">Usuario</span>`;

        tr.innerHTML = `
          <td data-label="Nombre">
            <div class="user-info">
              <div class="avatar">${(user.name || user.email || 'U')[0].toUpperCase()}</div>
              <span class="font-medium">${user.name || 'Sin nombre'}</span>
            </div>
          </td>
          <td data-label="Correo"><span class="text-gray">${user.email}</span></td>
          <td data-label="Rol">${roleBadge}</td>
          <td data-label="Fecha Registro"><span class="text-gray">${formatDate(user.created_at)}</span></td>
          <td data-label="Acciones" class="actions-cell">
            ${user.role !== 'admin' ? `
              <button class="btn-icon btn-delete" data-id="${user.id}" data-email="${user.email}" title="Eliminar usuario">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="3 6 5 6 21 6"></polyline>
                  <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                  <line x1="10" y1="11" x2="10" y2="17"></line>
                  <line x1="14" y1="11" x2="14" y2="17"></line>
                </svg>
              </button>
            ` : '<span class="text-muted text-sm">No eliminable</span>'}
          </td>
        `;
        
        usersTbody.appendChild(tr);
      });

      // Agregar event listeners a los botones de eliminar
      document.querySelectorAll('.btn-delete').forEach(element => {
        const btn = element as HTMLButtonElement;
        btn.addEventListener('click', async (e) => {
          const userId = btn.getAttribute('data-id') as string;
          const userEmail = btn.getAttribute('data-email');
          
          if (confirm(`¿Estás completamente seguro de que deseas eliminar al usuario ${userEmail}? Esta acción no se puede deshacer.`)) {
            btn.classList.add('loading');
            btn.disabled = true;
            
            try {
              await deleteAdminUser(userId);
              showMessage(`El usuario ${userEmail} ha sido eliminado correctamente.`);
              loadUsers(); // Recargar la tabla
            } catch (error: any) {
              console.error("Error eliminando usuario:", error);
              showMessage(`Hubo un error al eliminar el usuario: ${error.message}`, "error");
              btn.classList.remove('loading');
              btn.disabled = false;
            }
          }
        });
      });
    }

    // Inicialización y verificación de seguridad
    async function init() {
      try {
        const profile = await getUserProfile();
        
        if (!profile || profile.role !== 'admin') {
          // Redirigir si no es admin o no está logueado
          window.location.href = "/home";
          return;
        }

        // Si es admin, cargar la tabla
        loadUsers();
      } catch (error) {
        console.error("Error en inicialización del dashboard:", error);
        window.location.href = "/login";
      }
    }

    // Arrancar
    init();
  }

  // Ejecutar al cargar la página
  setupDashboard();
</script>

<style>
  .admin-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2.5rem 2rem;
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
  }

  .admin-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2.5rem;
  }

  .admin-header h1 {
    font-size: 1.8rem;
    font-weight: 700;
    color: #0f172a;
    margin: 0 0 0.5rem 0;
  }

  .admin-header p {
    color: #64748b;
    margin: 0;
    font-size: 1rem;
  }

  .btn-primary {
    background-color: #0f172a;
    color: white;
    border: none;
    border-radius: 8px;
    padding: 0.6rem 1.2rem;
    font-weight: 500;
    font-size: 0.95rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: all 0.2s ease;
    box-shadow: 0 2px 4px rgba(15, 23, 42, 0.1);
  }

  .btn-primary:hover {
    background-color: #1e293b;
    transform: translateY(-1px);
    box-shadow: 0 4px 6px rgba(15, 23, 42, 0.15);
  }

  .status-message {
    padding: 1rem 1.5rem;
    border-radius: 8px;
    margin-bottom: 1.5rem;
    font-weight: 500;
    animation: fadeIn 0.3s ease;
  }

  .status-message.success {
    background-color: #ecfdf5;
    color: #047857;
    border: 1px solid #a7f3d0;
  }

  .status-message.error {
    background-color: #fef2f2;
    color: #b91c1c;
    border: 1px solid #fecaca;
  }

  .table-container {
    background-color: white;
    border-radius: 12px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03);
    border: 1px solid #e2e8f0;
    overflow: hidden;
  }

  .users-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
  }

  .users-table th {
    background-color: #f8fafc;
    padding: 1.2rem 1.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: #475569;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 1px solid #e2e8f0;
  }

  .users-table td {
    padding: 1.2rem 1.5rem;
    border-bottom: 1px solid #f1f5f9;
    vertical-align: middle;
  }

  .users-table tbody tr {
    transition: background-color 0.15s ease;
  }

  .users-table tbody tr:hover {
    background-color: #f8fafc;
  }

  .users-table tbody tr:last-child td {
    border-bottom: none;
  }

  .user-info {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: #e2e8f0;
    color: #334155;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 1.1rem;
  }

  .font-medium {
    font-weight: 500;
    color: #0f172a;
  }

  .text-gray {
    color: #64748b;
    font-size: 0.95rem;
  }

  .text-muted {
    color: #94a3b8;
  }

  .text-sm {
    font-size: 0.85rem;
  }

  .text-right {
    text-align: right;
  }

  .actions-cell {
    text-align: right;
  }

  .badge {
    padding: 0.35rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.025em;
  }

  .badge-admin {
    background-color: #ede9fe;
    color: #6d28d9;
  }

  .badge-user {
    background-color: #f1f5f9;
    color: #475569;
  }

  .btn-icon {
    background: transparent;
    border: none;
    color: #94a3b8;
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 6px;
    transition: all 0.2s ease;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .btn-delete:hover {
    background-color: #fee2e2;
    color: #ef4444;
  }

  .btn-delete.loading {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .loading-state, .empty-state {
    padding: 4rem 2rem;
    text-align: center;
    color: #64748b;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }

  .spinner {
    width: 40px;
    height: 40px;
    border: 3px solid #f1f5f9;
    border-top-color: #0f172a;
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .admin-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
    
    .users-table, .users-table tbody, .users-table tr, .users-table td {
      display: block;
      width: 100%;
    }
    
    .users-table thead {
      display: none;
    }
    
    .users-table tr {
      margin-bottom: 1rem;
      border: 1px solid #e2e8f0;
      border-radius: 8px;
      background-color: #fafafa;
    }
    
    .users-table td {
      text-align: right;
      padding: 1rem;
      position: relative;
      border-bottom: 1px solid #f1f5f9;
    }
    
    .users-table td:last-child {
      border-bottom: none;
    }
    
    .users-table td::before {
      content: attr(data-label);
      position: absolute;
      left: 1rem;
      top: 50%;
      transform: translateY(-50%);
      font-weight: 600;
      color: #64748b;
      font-size: 0.85rem;
      text-transform: uppercase;
    }
    
    .user-info {
      justify-content: flex-end;
    }
  }
</style>
