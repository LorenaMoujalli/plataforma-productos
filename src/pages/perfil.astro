---
import DashboardLayout from "../layouts/DashboardLayout.astro";
---

<DashboardLayout title="Perfil">
	<!-- Espacio en blanco para que agregues el contenido de tu perfil aquí -->
	<div class="profile-container">
		<!-- CONTENEDOR PRINCIPAL DE LA SECCIÓN PERFIL -->
<div class="profile-section-container" style="max-width: 1200px; width: 100%; margin: 0 auto; padding: 40px 20px; font-family: 'Inter', Arial, sans-serif; background-color: #ffffff; color: #000000; box-sizing: border-box;">
  
  <!-- CABECERA: TÍTULO Y BOTÓN "VER TARJETA" -->
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
    <h1 style="font-size: 42px; font-weight: 800; color: #d32f2f; margin: 0; font-family: inherit;">Perfil</h1>
    <a href="#" style="text-decoration: none; color: #000000; font-size: 14px; font-weight: 700; border: 1px solid #d32f2f; padding: 10px 24px; border-radius: 8px; background-color: transparent; transition: all 0.3s ease;">
      Ver tarjeta
    </a>
  </div>

  <!-- MALLA PRINCIPAL REBALANCEADA -->
  <div class="profile-grid" style="display: flex; gap: 30px; width: 100%; box-sizing: border-box;">
    
    <!-- TARJETA IZQUIERDA: INFORMACIÓN GENERAL -->
    <div style="flex: 2.3; border: 1px solid #e0e0e0; border-radius: 20px; padding: 40px; background-color: #fbfbfb; box-sizing: border-box;">
      <h2 style="font-size: 28px; font-weight: 700; margin: 0 0 6px 0;">Andrea Pérez</h2>
      <p style="font-size: 14px; color: #757575; font-style: italic; margin: 0 0 40px 0;">Información general</p>
      
      <!-- CONTENEDOR DE CAMPOS EN DOS COLUMNAS ANCHAS -->
      <div class="profile-fields-inputs" style="display: flex; flex-wrap: wrap; gap: 30px 24px;">
        <!-- Campo: Email -->
        <div style="width: calc(50% - 12px); min-width: 260px; box-sizing: border-box;">
          <label style="display: block; font-size: 13px; font-weight: 600; color: #000000; margin-bottom: 10px;">Email</label>
          <div style="background-color: #f0f0f0; padding: 14px 16px; border-radius: 4px; font-size: 14px; color: #212121; box-sizing: border-box;">
            Empresaficticia@mail.com
          </div>
        </div>
        <!-- Campo: Fecha de unión -->
        <div style="width: calc(50% - 12px); min-width: 260px; box-sizing: border-box;">
          <label style="display: block; font-size: 13px; font-weight: 600; color: #000000; margin-bottom: 10px;">Fecha de unión</label>
          <div style="background-color: #f0f0f0; padding: 14px 16px; border-radius: 4px; font-size: 14px; color: #212121; box-sizing: border-box;">
            Se unió el 00/00/0000
          </div>
        </div>
        <!-- Campo: Empresa -->
        <div style="width: calc(50% - 12px); min-width: 260px; box-sizing: border-box;">
          <label style="display: block; font-size: 13px; font-weight: 600; color: #000000; margin-bottom: 10px;">Company</label>
          <div style="background-color: #f0f0f0; padding: 14px 16px; border-radius: 4px; font-size: 14px; color: #212121; box-sizing: border-box;">
            Empresa tomada de email
          </div>
        </div>
        <!-- Botón: Editar Información -->
        <div style="width: calc(50% - 12px); min-width: 260px; display: flex; align-items: flex-end; box-sizing: border-box;">
          <button type="button" style="width: 100%; background-color: #da291c; color: #ffffff; border: none; padding: 14px; border-radius: 4px; font-size: 15px; font-weight: 700; cursor: pointer; transition: background-color 0.2s; height: 48px; font-family: inherit;">
            Editar información
          </button>
        </div>
      </div>
    </div>

    <!-- COLUMNA DERECHA: ACCIONES ACCESORIAS -->
    <div class="profile-sidebar" style="flex: 1; min-width: 300px; display: flex; flex-direction: column; gap: 24px; box-sizing: border-box;">
      
      <!-- TARJETA: CONTRASEÑA -->
      <div style="border: 1px solid #e0e0e0; border-radius: 20px; padding: 35px 30px; background-color: #fbfbfb; text-align: center; box-sizing: border-box; display: flex; flex-direction: column; justify-content: center; align-items: center; flex: 1;">
        <h3 style="font-size: 19px; font-weight: 700; margin: 0 0 20px 0; max-width: 220px; line-height: 1.3;">¿Olvidaste tu contraseña?</h3>
        <button type="button" style="width: 100%; max-width: 240px; background-color: #da291c; color: #ffffff; border: none; padding: 12px 20px; border-radius: 4px; font-size: 14px; font-weight: 700; cursor: pointer; transition: background-color 0.2s; font-family: inherit;">
          Reestablecer contraseña
        </button>
      </div>

      <!-- TARJETA: CIERRE DE SESIÓN -->
      <div style="border: 1px solid #e0e0e0; border-radius: 20px; padding: 35px 30px; background-color: #fbfbfb; text-align: center; box-sizing: border-box; display: flex; flex-direction: column; justify-content: center; align-items: center; flex: 1;">
        <h3 style="font-size: 19px; font-weight: 700; margin: 0 0 20px 0; line-height: 1.3;">Cierre de sesión</h3>
        <button type="button" style="width: 100%; max-width: 240px; background-color: #da291c; color: #ffffff; border: none; padding: 12px 20px; border-radius: 4px; font-size: 14px; font-weight: 700; cursor: pointer; transition: background-color 0.2s; font-family: inherit;">
          Cerrar
        </button>
      </div>

    </div>

  </div>

  <!-- ESTILOS PARA COMPORTAMIENTO MÓVIL Y HOVERS -->
  <style>
    .profile-section-container a:hover {
      background-color: #d32f2f !important;
      color: #ffffff !important;
    }
    .profile-section-container button:hover {
      background-color: #b71c1c !important;
    }

    @media (max-width: 992px) {
      .profile-grid {
        flex-direction: column !important;
      }
      .profile-sidebar {
        flex-direction: row !important;
      }
      .profile-sidebar > div {
        flex: 1;
      }
    }

    @media (max-width: 680px) {
      .profile-fields-inputs > div {
        width: 100% !important;
      }
      .profile-sidebar {
        flex-direction: column !important;
      }
    }
  </style>
</div>
  
	</div>
</DashboardLayout>

<script>
	import { supabase } from "../lib/supabase.js";

	// Verificar si el usuario tiene una sesión activa, si no, redirigir a /login
	const {
		data: { session },
	} = await supabase.auth.getSession();

	if (!session) {
		window.location.href = "/login";
	}
</script>

<style>
	.profile-container {
		min-height: 400px;
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		color: #64748b;
	}
</style>
