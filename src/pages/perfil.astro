<script>
	import { supabase } from "../lib/supabase.js";
	import { getCompaniesForSelect } from "../services/coupons-admin.js";
	import { getAllowedDomainNames } from "../services/domains.js";
	import {
		showToast,
		showAlert,
		showConfirm,
	} from "../utils/notifications.js";
	import {
		signOutUser,
		updateAuthEmail,
		directResetPassword,
	} from "../services/auth.js";

	// --- Referencias UI ---
	const displayNameEl = document.getElementById("profile-display-name")!;
	const displayEmailEl = document.getElementById("profile-display-email")!;
	const displayJoinedEl = document.getElementById("profile-display-joined")!;
	const displayCompanyEl = document.getElementById(
		"profile-display-company",
	)!;

	const btnEditInfo = document.getElementById(
		"btn-edit-info",
	) as HTMLButtonElement;
	const btnResetPassword = document.getElementById(
		"btn-reset-password",
	) as HTMLButtonElement;
	const btnLogout = document.getElementById(
		"btn-logout",
	) as HTMLButtonElement;

	// Elementos Modal Edición
	const editModalOverlay = document.getElementById(
		"edit-modal-overlay",
	) as HTMLDivElement;
	const btnCloseModal = document.getElementById(
		"btn-close-modal",
	) as HTMLButtonElement;
	const editProfileForm = document.getElementById(
		"edit-profile-form",
	) as HTMLFormElement;
	const inputName = document.getElementById("input-name") as HTMLInputElement;
	const inputEmail = document.getElementById(
		"input-email",
	) as HTMLInputElement;
	const selectCompany = document.getElementById(
		"select-company",
	) as HTMLSelectElement;
	const btnSaveProfile = document.getElementById(
		"btn-save-profile",
	) as HTMLButtonElement;

	// Elementos Modal Reset Contraseña
	const resetModalOverlay = document.getElementById(
		"reset-password-modal-overlay",
	) as HTMLDivElement;
	const btnCloseResetModal = document.getElementById(
		"btn-close-reset-modal",
	) as HTMLButtonElement;
	const resetPasswordForm = document.getElementById(
		"reset-password-form",
	) as HTMLFormElement;
	const inputResetEmail = document.getElementById(
		"input-reset-email",
	) as HTMLInputElement;
	const inputNewPassword = document.getElementById(
		"input-new-password",
	) as HTMLInputElement;
	const inputConfirmPassword = document.getElementById(
		"input-confirm-password",
	) as HTMLInputElement;
	const btnConfirmReset = document.getElementById(
		"btn-confirm-reset",
	) as HTMLButtonElement;

	// --- Cargar Sesión y Validar ---
	const {
		data: { session },
	} = await supabase.auth.getSession();

	if (!session) {
		window.location.href = "/login";
	}

	const userId = session?.user?.id;
	let allowedDomains: string[] = [];
	let companiesList: Array<{ id: number; name: string }> = [];
	let userProfile: any = null;

	// --- Funciones de Carga de Datos ---
	async function loadAllData() {
		try {
			// 1. Obtener Dominios Permitidos
			allowedDomains = await getAllowedDomainNames().catch(() => []);

			// 2. Obtener Listado de Empresas
			companiesList = await getCompaniesForSelect().catch(() => []);

			// Llenar select de la modal
			selectCompany.innerHTML =
				'<option value="">Selecciona una empresa</option>';
			companiesList.forEach((c) => {
				const option = document.createElement("option");
				option.value = c.id.toString();
				option.textContent = c.name;
				selectCompany.appendChild(option);
			});

			// 3. Obtener Perfil del Usuario
			const { data, error } = await supabase
				.from("profiles")
				.select("*, companies(id, name)")
				.eq("id", userId)
				.maybeSingle();

			if (error) throw error;
			userProfile = data;

			// Actualizar UI principal
			const nameVal =
				userProfile?.name ||
				session?.user?.user_metadata?.name ||
				"Sin nombre";
			const emailVal =
				userProfile?.email || session?.user?.email || "Sin email";
			const joinedVal = new Date(
				userProfile?.created_at || session?.user?.created_at,
			).toLocaleDateString("es-ES", {
				day: "2-digit",
				month: "2-digit",
				year: "numeric",
			});
			const companyVal =
				userProfile?.companies?.name || "Sin empresa asignada";

			displayNameEl.textContent = nameVal;
			displayEmailEl.textContent = emailVal;
			displayJoinedEl.textContent = `Se unió el ${joinedVal}`;
			displayCompanyEl.textContent = companyVal;

			// Actualizar Avatar en UI
			const avatarImg = document.getElementById(
				"profile-avatar-img",
			) as HTMLImageElement;
			const avatarPlaceholder = document.getElementById(
				"profile-avatar-placeholder",
			);
			if (userProfile?.avatar_url) {
				if (avatarImg) {
					avatarImg.src = userProfile.avatar_url;
					avatarImg.style.display = "block";
				}
				if (avatarPlaceholder) {
					avatarPlaceholder.style.display = "none";
				}
			} else {
				if (avatarImg) {
					avatarImg.src = "";
					avatarImg.style.display = "none";
				}
				if (avatarPlaceholder) {
					avatarPlaceholder.style.display = "block";
				}
			}

			// Actualizar los datos del carnet virtual
			const cardVirtualName =
				document.getElementById("card-virtual-name");
			const cardVirtualCompany = document.getElementById(
				"card-virtual-company",
			);
			const cardVirtualEmail =
				document.getElementById("card-virtual-email");
			const cardVirtualJoined = document.getElementById(
				"card-virtual-joined",
			);
			const cardQrName = document.getElementById("card-qr-name");

			const joinedDateObj = new Date(
				userProfile?.created_at || session?.user?.created_at,
			);
			const joinedValLong = joinedDateObj.toLocaleDateString("es-ES", {
				day: "numeric",
				month: "long",
				year: "numeric",
			});

			if (cardVirtualName) cardVirtualName.textContent = nameVal;
			if (cardVirtualCompany) cardVirtualCompany.textContent = companyVal;
			if (cardVirtualEmail) cardVirtualEmail.textContent = emailVal;
			if (cardVirtualJoined)
				cardVirtualJoined.textContent = joinedValLong;
			if (cardQrName) cardQrName.textContent = nameVal;

				// Poblar fecha de expiración en el carnet
				const cardVirtualExpiration = document.getElementById("card-virtual-expiration");
				if (cardVirtualExpiration) {
					const expDate = userProfile?.expiration_date;
					if (!expDate) {
						cardVirtualExpiration.innerHTML = `<span style="display:inline-flex;justify-content:center;align-items:center;gap:0.35rem;padding:0.2rem 0.7rem;border-radius:9999px;font-size:0.75rem;font-weight:600;background:#f1f5f9;color:#64748b;border:1px solid #e2e8f0;">
							<svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
							No especificado
						</span>`;
					} else {
						const exp = new Date(expDate + 'T00:00:00');
						const today = new Date(); today.setHours(0,0,0,0);
						const isExpired = exp < today;
						const formatted = exp.toLocaleDateString('es-ES', { day: '2-digit', month: 'long', year: 'numeric' });
						if (isExpired) {
							cardVirtualExpiration.innerHTML = `<span style="display:inline-flex;justify-content:center;align-items:center;gap:0.35rem;padding:0.2rem 0.7rem;border-radius:9999px;font-size:0.75rem;font-weight:600;background:#fef2f2;color:#dc2626;border:1px solid #fecaca;">
								<svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
								${formatted}
							</span>`;
						} else {
							cardVirtualExpiration.innerHTML = `<span style="display:inline-flex;justify-content:center;align-items:center;gap:0.35rem;padding:0.2rem 0.7rem;border-radius:9999px;font-size:0.75rem;font-weight:600;background:#f0fdf4;color:#16a34a;border:1px solid #bbf7d0;">
								<svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
								${formatted}
							</span>`;
						}
					}
				}

			// Actualizar Foto del carnet virtual
			const cardAvatarImg = document.getElementById(
				"card-avatar-img",
			) as HTMLImageElement;
			const cardAvatarPlaceholder = document.getElementById(
				"card-avatar-placeholder",
			);
			if (userProfile?.avatar_url) {
				if (cardAvatarImg) {
					cardAvatarImg.src = userProfile.avatar_url;
					cardAvatarImg.style.display = "block";
				}
				if (cardAvatarPlaceholder) {
					cardAvatarPlaceholder.style.display = "none";
				}
			} else {
				if (cardAvatarImg) {
					cardAvatarImg.src = "";
					cardAvatarImg.style.display = "none";
				}
				if (cardAvatarPlaceholder) {
					cardAvatarPlaceholder.style.display = "block";
				}
			}

			// Llenar inputs de modal
			inputName.value = nameVal;
			inputEmail.value = emailVal;
			if (userProfile?.company_id) {
				selectCompany.value = userProfile.company_id.toString();
			} else {
				selectCompany.value = "";
			}

			// Llenar email en modal de reset
			if (inputResetEmail) {
				inputResetEmail.value = emailVal;
			}
		} catch (err: any) {
			console.error("Error al cargar la información del perfil:", err);
			showToast({
				text: "Error al cargar la información del perfil.",
				icon: "error",
			});
		}
	}

	// --- Generación del QR ---
	async function generateQR(uuid: string) {
		try {
			// Prioriza la variable de entorno PUBLIC_SITE_URL si está definida.
			const envUrl = import.meta.env.PUBLIC_SITE_URL;
			let baseUrl = "";

			if (envUrl && envUrl.trim() !== "") {
				baseUrl = envUrl.trim().replace(/\/$/, "");
			} else {
				// En local, usamos el origen actual (window.location.origin).
				// NOTA: Para que funcione en el móvil, debes acceder a la web en tu PC
				// usando tu IP local (ej: http://192.168.1.15:4321) en lugar de localhost.
				baseUrl = window.location.origin;
			}

			const qrUrl = `${baseUrl}/validar?id=${uuid}`;

			// @ts-ignore - Ignorar falta de tipos para qrcode
			const QRCode = (await import("qrcode")).default;
			const canvas = document.getElementById(
				"canvas-qr",
			) as HTMLCanvasElement;
			const loadingText = document.getElementById("qr-loading-text");

			if (!canvas) return;

			await QRCode.toCanvas(canvas, qrUrl, {
				width: 160,
				margin: 1,
				color: {
					dark: "#000000",
					light: "#ffffff",
				},
			});

			canvas.style.display = "block";
			if (loadingText) loadingText.style.display = "none";
		} catch (err) {
			console.error("Error generando QR:", err);
			const loadingText = document.getElementById("qr-loading-text");
			if (loadingText) loadingText.textContent = "Error al generar QR";
		}
	}

	// Cargar al inicializar
	if (userId) {
		await loadAllData();
		// Generar el QR con el UUID del usuario autenticado
		await generateQR(userId);
	}

	// --- Manejo de la Modal Edición ---
	btnEditInfo.addEventListener("click", () => {
		editModalOverlay.style.display = "flex";
	});

	function closeModal() {
		editModalOverlay.style.display = "none";
	}

	btnCloseModal.addEventListener("click", closeModal);
	editModalOverlay.addEventListener("click", (e) => {
		if (e.target === editModalOverlay) {
			closeModal();
		}
	});

	// --- Manejo de la Modal Reset Contraseña ---
	btnResetPassword.addEventListener("click", () => {
		resetModalOverlay.style.display = "flex";
		inputNewPassword.value = "";
		inputConfirmPassword.value = "";
	});

	function closeResetModal() {
		resetModalOverlay.style.display = "none";
	}

	btnCloseResetModal.addEventListener("click", closeResetModal);
	resetModalOverlay.addEventListener("click", (e) => {
		if (e.target === resetModalOverlay) {
			closeResetModal();
		}
	});

	// --- Manejo del Modal de Tarjeta de Identificación ---
	const btnViewCard = document.getElementById(
		"btn-view-card",
	) as HTMLAnchorElement;
	const cardModalOverlay = document.getElementById(
		"card-modal-overlay",
	) as HTMLDivElement;
	const btnCloseCardModal = document.getElementById(
		"btn-close-card-modal",
	) as HTMLButtonElement;

	if (btnViewCard && cardModalOverlay) {
		btnViewCard.addEventListener("click", (e) => {
			e.preventDefault();
			const virtualView = document.getElementById("card-virtual-view");
			const qrView = document.getElementById("card-qr-view");
			if (virtualView) virtualView.style.display = "block";
			if (qrView) qrView.style.display = "none";
			cardModalOverlay.style.display = "flex";
		});
	}

	// Toggle buttons entre carnet virtual y qr
	const btnToQrView = document.getElementById("btn-to-qr-view");
	const btnToVirtualView = document.getElementById("btn-to-virtual-view");
	const virtualView = document.getElementById("card-virtual-view");
	const qrView = document.getElementById("card-qr-view");

	if (btnToQrView && virtualView && qrView) {
		btnToQrView.addEventListener("click", () => {
			virtualView.style.display = "none";
			qrView.style.display = "block";
		});
	}

	if (btnToVirtualView && virtualView && qrView) {
		btnToVirtualView.addEventListener("click", () => {
			virtualView.style.display = "block";
			qrView.style.display = "none";
		});
	}

	function closeCardModal() {
		if (cardModalOverlay) cardModalOverlay.style.display = "none";
	}

	if (btnCloseCardModal) {
		btnCloseCardModal.addEventListener("click", closeCardModal);
	}

	if (cardModalOverlay) {
		cardModalOverlay.addEventListener("click", (e) => {
			if (e.target === cardModalOverlay) {
				closeCardModal();
			}
		});
	}

	// --- Toggle Password Visibility ---
	document.querySelectorAll(".toggle-password-btn").forEach((btn) => {
		btn.addEventListener("click", () => {
			const wrapper = btn.closest(".password-wrapper");
			const input = wrapper?.querySelector("input");
			const eyeOpen = btn.querySelector(".eye-open") as HTMLElement;
			const eyeClosed = btn.querySelector(".eye-closed") as HTMLElement;

			if (input) {
				if (input.type === "password") {
					input.type = "text";
					eyeOpen.style.display = "none";
					eyeClosed.style.display = "block";
				} else {
					input.type = "password";
					eyeOpen.style.display = "block";
					eyeClosed.style.display = "none";
				}
			}
		});
	});

	// --- Validación de Dominio ---
	function isDomainAllowed(email: string) {
		const domain = email.split("@")[1];
		return (
			domain &&
			(allowedDomains.length === 0 ||
				allowedDomains.includes(domain.toLowerCase()))
		);
	}

	// --- Guardar Cambios Perfil ---
	editProfileForm.addEventListener("submit", async (e) => {
		e.preventDefault();
		const newName = inputName.value.trim();
		const newEmail = inputEmail.value.trim();
		const newCompanyId = selectCompany.value
			? parseInt(selectCompany.value)
			: null;

		if (newEmail && !isDomainAllowed(newEmail)) {
			showToast({
				text: "Solo se permiten correos electrónicos de dominios autorizados.",
				icon: "error",
			});
			return;
		}

		btnSaveProfile.disabled = true;
		btnSaveProfile.textContent = "Guardando...";

		try {
			// 1. Actualizar perfil en public.profiles (nombre, email de contacto, empresa)
			const { error: rpcError } = await supabase.rpc(
				"update_own_profile",
				{
					p_name: newName,
					p_email: newEmail,
					p_company_id: newCompanyId,
				},
			);
			if (rpcError) throw rpcError;

			// 2. Si el email cambió, actualizar también en auth.users directamente (sin rate limit ni confirmación)
			const currentEmail =
				userProfile?.email || session?.user?.email || "";
			if (newEmail && newEmail !== currentEmail) {
				const { error: emailError } = await supabase.rpc(
					"update_own_email",
					{
						p_email: newEmail,
					},
				);
				if (emailError) throw emailError;
			}

			await showAlert({
				title: "¡Perfil Actualizado!",
				text: "La información de tu perfil ha sido modificada correctamente.",
				icon: "success",
				confirmButtonText: "Aceptar",
			});

			closeModal();
			await loadAllData();
		} catch (err: any) {
			console.error("Error al actualizar perfil:", err);
			showToast({
				text: err.message || "Error al guardar los cambios.",
				icon: "error",
			});
		} finally {
			btnSaveProfile.disabled = false;
			btnSaveProfile.textContent = "Guardar cambios";
		}
	});

	// --- Acción Reset Contraseña ---
	resetPasswordForm.addEventListener("submit", async (e) => {
		e.preventDefault();
		const email = inputResetEmail.value;
		const newPassword = inputNewPassword.value;
		const confirmPassword = inputConfirmPassword.value;

		if (newPassword !== confirmPassword) {
			showToast({ text: "Las contraseñas no coinciden.", icon: "error" });
			return;
		}

		if (newPassword.length < 6) {
			showToast({
				text: "La contraseña debe tener al menos 6 caracteres.",
				icon: "error",
			});
			return;
		}

		btnConfirmReset.disabled = true;
		btnConfirmReset.textContent = "Cambiando...";

		try {
			const success = await directResetPassword(email, newPassword);
			if (!success) {
				showToast({
					text: "Ocurrió un error al intentar actualizar la contraseña.",
					icon: "error",
				});
				return;
			}

			await showAlert({
				title: "¡Contraseña Cambiada!",
				text: "Tu contraseña ha sido actualizada correctamente.",
				icon: "success",
				confirmButtonText: "Aceptar",
			});

			closeResetModal();
		} catch (err: any) {
			showToast({
				text: err.message || "Error al cambiar la contraseña.",
				icon: "error",
			});
		} finally {
			btnConfirmReset.disabled = false;
			btnConfirmReset.textContent = "Cambiar contraseña";
		}
	});

	btnLogout.addEventListener("click", async () => {
		const ok = await showConfirm({
			title: "¿Está seguro de que quiere cerrar sesión?",
			text: "",
			confirmButtonText: "Cerrar",
			cancelButtonText: "Cancelar",
		});

		if (!ok) return;

		try {
			await signOutUser();
			window.location.href = "/login";
		} catch (err: any) {
			showToast({ text: "Error al cerrar sesión.", icon: "error" });
		}
	});

	// --- Manejo de la Carga de Avatar ---
	const avatarInput = document.getElementById(
		"avatar-input",
	) as HTMLInputElement;
	if (avatarInput) {
		avatarInput.addEventListener("change", async (e) => {
			const target = e.target as HTMLInputElement;
			const file = target.files?.[0];
			if (!file) return;

			// Validar tipo de archivo
			if (!file.type.startsWith("image/")) {
				showToast({
					text: "Por favor, selecciona un archivo de imagen válido.",
					icon: "error",
				});
				return;
			}

			// Validar tamaño (ej: 2MB)
			if (file.size > 2 * 1024 * 1024) {
				showToast({
					text: "La imagen no debe superar los 2MB.",
					icon: "error",
				});
				return;
			}

			try {
				showToast({
					text: "Subiendo foto de perfil...",
					icon: "info",
				});

				const ext = file.name.split(".").pop();
				const path = `avatars/${userId}-${Date.now()}.${ext}`;

				// Subir a storage (usando el bucket 'logos' existente)
				const { error: uploadError } = await supabase.storage
					.from("logos")
					.upload(path, file, {
						cacheControl: "3600",
						upsert: true,
					});

				if (uploadError) throw uploadError;

				// Obtener URL pública
				const { data: urlData } = supabase.storage
					.from("logos")
					.getPublicUrl(path);

				const publicUrl = urlData.publicUrl;

				// Guardar en la tabla de perfiles
				const { error: updateError } = await supabase
					.from("profiles")
					.update({ avatar_url: publicUrl })
					.eq("id", userId);

				if (updateError) throw updateError;

				showToast({
					text: "Foto de perfil actualizada correctamente.",
					icon: "success",
				});

				await loadAllData();
			} catch (err: any) {
				console.error("Error al actualizar la foto de perfil:", err);
				showToast({
					text: "Error al subir la foto de perfil.",
					icon: "error",
				});
			}
		});
	}
</script>

<style>
	.profile-container {
		position: relative;
		min-height: 400px;
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		color: #64748b;
	}
</style>
